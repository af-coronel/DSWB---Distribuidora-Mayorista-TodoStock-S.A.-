doctype html
html(lang="es")
  head
    title TodoStock S.A.
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css")
body
  nav.navbar.navbar-dark.bg-dark.px-4.mb-4
    span.navbar-brand.fw-bold TodoStock S.A.
    form(action="/api/auth/logout", method="POST")
      button.btn.btn-outline-light.btn-sm(type="submit")
        i.bi.bi-box-arrow-right.me-1
        | Cerrar sesión

  .container
    h1 Gestión de Socios de Negocio
    hr

    // --- SISTEMA DE TABS ---
    ul.nav.nav-tabs.mb-4
      li.nav-item
        a.nav-link(class=activeTab === 'clients' ? 'active font-weight-bold' : '', href="/api/clients")
          i.bi.bi-people-fill.me-2
          | Clientes
      li.nav-item
        a.nav-link(class=activeTab === 'vendors' ? 'active font-weight-bold' : '', href="/api/vendors")
          i.bi.bi-truck.me-2
          | Proveedores
      li.nav-item
        a.nav-link(class=activeTab === 'products' ? 'active font-weight-bold' : '', href="/api/products")
          i.bi.bi-box-seam.me-2
          | Productos
      li.nav-item
        a.nav-link(class=activeTab === 'orders' ? 'active font-weight-bold' : '', href="/api/orders")
          i.bi.bi-cart-check.me-2
          | Órdenes

block content