doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title TodoStock S.A.
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css")
  body
    if activeTab
      nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.px-4.py-2
        span.navbar-brand.fw-bold.fs-5
          i.bi.bi-boxes.me-2
          | TodoStock S.A.
        form.ms-auto(action="/api/auth/logout", method="POST")
          button.btn.btn-outline-light.btn-sm(type="submit")
            i.bi.bi-box-arrow-right.me-1
            | Cerrar sesión

      .bg-light.border-bottom.px-4
        ul.nav.nav-tabs.border-0
          li.nav-item
            a.nav-link.px-3(class=activeTab === 'clients' ? 'active fw-semibold' : '', href="/api/clients")
              i.bi.bi-people-fill.me-1
              | Clientes
          li.nav-item
            a.nav-link.px-3(class=activeTab === 'vendors' ? 'active fw-semibold' : '', href="/api/vendors")
              i.bi.bi-truck.me-1
              | Proveedores
          li.nav-item
            a.nav-link.px-3(class=activeTab === 'products' ? 'active fw-semibold' : '', href="/api/products")
              i.bi.bi-box-seam.me-1
              | Productos
          li.nav-item
            a.nav-link.px-3(class=activeTab === 'orders' ? 'active fw-semibold' : '', href="/api/orders")
              i.bi.bi-cart-check.me-1
              | Órdenes
          li.nav-item
            a.nav-link.px-3(class=activeTab === 'inventory' ? 'active fw-semibold' : '', href="/api/inventory")
              i.bi.bi-archive.me-1
              | Inventario
          li.nav-item
            a.nav-link.px-3(class=activeTab === 'transactions' ? 'active fw-semibold' : '', href="/api/transactions")
              i.bi.bi-cash-coin.me-1
              | Finanzas

    block content

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
    script.
      document.addEventListener('DOMContentLoaded', () => {
        document.querySelectorAll('form').forEach(form => {
          form.addEventListener('submit', function() {
            if (this.checkValidity()) {
              const btn = this.querySelector('[type="submit"]');
              if (btn && !btn.dataset.noLoading) {
                btn.disabled = true;
                btn.innerHTML =
                  '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>Procesando...';
              }
            }
          });
        });
      });
    block scripts
