doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title TodoStock S.A.
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css")
    script(src="https://unpkg.com/htmx.org@2.0.4/dist/htmx.min.js", defer)
    style.
      .sidebar {
        width: 240px;
        min-height: 100vh;
        position: fixed;
        top: 0;
        left: 0;
        z-index: 100;
        overflow: hidden;
        transition: width 0.22s ease;
      }
      .sidebar.collapsed { width: 64px; }

      .sidebar .sidebar-text { white-space: nowrap; }
      .sidebar.collapsed .sidebar-text { display: none; }

      .sidebar .nav-link {
        color: rgba(255, 255, 255, .65);
        border-radius: 6px;
        padding: .5rem .75rem;
        font-size: .925rem;
        display: flex;
        align-items: center;
        white-space: nowrap;
      }
      .sidebar .nav-link:hover { color: #fff; background-color: rgba(255, 255, 255, .1); }
      .sidebar .nav-link.active { color: #fff; background-color: rgba(255, 255, 255, .15); font-weight: 600; }
      .sidebar.collapsed .nav-link { justify-content: center; padding: .5rem; }

      .sidebar-toggle-btn {
        background: none;
        border: none;
        color: rgba(255,255,255,.55);
        cursor: pointer;
        padding: .2rem .4rem;
        border-radius: 4px;
        line-height: 1;
        flex-shrink: 0;
      }
      .sidebar-toggle-btn:hover { color: #fff; background: rgba(255,255,255,.12); }

      .sidebar.collapsed .sidebar-brand-area { display: none !important; }
      .sidebar.collapsed .sidebar-header { justify-content: center; }

      .main-content {
        flex: 1;
        margin-left: 240px;
        min-height: 100vh;
        min-width: 0;
        transition: margin-left 0.22s ease;
      }
      .main-content.expanded { margin-left: 64px; }

      .main-content .container {
        max-width: 100% !important;
        width: 100% !important;
        padding-left: 1.75rem;
        padding-right: 1.75rem;
      }

      .status-pill,
      .entity-pill {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        border-radius: 999px;
        padding: .35rem .7rem;
        font-size: .78rem;
        font-weight: 700;
        letter-spacing: .01em;
      }

      .status-attention {
        background: #fff3cd;
        color: #7a4b00;
        border: 1px solid #f6d68a;
      }

      .status-progress {
        background: #e1effe;
        color: #114a78;
        border: 1px solid #b8d7f5;
      }

      .status-done {
        background: #dcf5e7;
        color: #17603a;
        border: 1px solid #b9e8cd;
      }

      .status-cancelled {
        background: #fde2e4;
        color: #8c2331;
        border: 1px solid #f5bcc4;
      }

      .status-neutral {
        background: #edf1f5;
        color: #475467;
        border: 1px solid #d8e0e8;
      }

      .entity-purchase {
        background: #eaf2ff;
        color: #1d4f91;
        border: 1px solid #c8daf8;
      }

      .entity-sale {
        background: #e7f8f2;
        color: #116149;
        border: 1px solid #c3eadc;
      }

      .entity-payment {
        background: #ebe9ff;
        color: #4a3fa1;
        border: 1px solid #d1cbfa;
      }

      .entity-collection {
        background: #e8f7ee;
        color: #1e6a48;
        border: 1px solid #c6e8d3;
      }
  body
    if activeTab
      .d-flex
        nav.sidebar.bg-dark.d-flex.flex-column.p-3
          .sidebar-header.d-flex.align-items-center.justify-content-between.mb-4
            .sidebar-brand-area.d-flex.align-items-center.overflow-hidden
              i.bi.bi-boxes.text-white.fs-5.flex-shrink-0
              span.sidebar-text.fw-bold.fs-6.text-white.ms-2 TodoStock S.A.
            button.sidebar-toggle-btn#sidebar-toggle(type="button", title="Colapsar menú")
              i#toggle-icon.bi.bi-chevron-left

          ul.nav.nav-pills.flex-column.gap-1.flex-grow-1
            li.nav-item
              a.nav-link(class=activeTab === 'clients' ? 'active' : '', href="/api/clients", title="Clientes")
                i.bi.bi-people-fill.flex-shrink-0
                span.sidebar-text.ms-2 Clientes
            li.nav-item
              a.nav-link(class=activeTab === 'vendors' ? 'active' : '', href="/api/vendors", title="Proveedores")
                i.bi.bi-truck.flex-shrink-0
                span.sidebar-text.ms-2 Proveedores
            li.nav-item
              a.nav-link(class=activeTab === 'products' ? 'active' : '', href="/api/products", title="Productos")
                i.bi.bi-box-seam.flex-shrink-0
                span.sidebar-text.ms-2 Productos
            li.nav-item
              a.nav-link(class=activeTab === 'orders' ? 'active' : '', href="/api/orders?type=PURCHASE", title="Órdenes")
                i.bi.bi-cart-check.flex-shrink-0
                span.sidebar-text.ms-2 Órdenes
            li.nav-item
              a.nav-link(class=activeTab === 'inventory' ? 'active' : '', href="/api/inventory", title="Inventario")
                i.bi.bi-archive.flex-shrink-0
                span.sidebar-text.ms-2 Inventario
            li.nav-item
              a.nav-link(class=activeTab === 'transactions' ? 'active' : '', href="/api/transactions?type=PAYMENT", title="Finanzas")
                i.bi.bi-cash-coin.flex-shrink-0
                span.sidebar-text.ms-2 Finanzas

          .mt-auto
            form(action="/api/auth/logout", method="POST")
              button.btn.btn-outline-light.btn-sm.w-100(type="submit", title="Cerrar sesión")
                i.bi.bi-box-arrow-right.flex-shrink-0
                span.sidebar-text.ms-1 Cerrar sesión

        main.main-content.bg-light
          block content

    else
      block content

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
    script.
      (function () {
        var sidebar = document.querySelector('.sidebar');
        var mainContent = document.querySelector('.main-content');
        var toggleIcon = document.getElementById('toggle-icon');

        function applyState(collapsed) {
          if (!sidebar) return;
          if (collapsed) {
            sidebar.classList.add('collapsed');
            if (mainContent) mainContent.classList.add('expanded');
            if (toggleIcon) {
              toggleIcon.classList.remove('bi-chevron-left');
              toggleIcon.classList.add('bi-chevron-right');
            }
          } else {
            sidebar.classList.remove('collapsed');
            if (mainContent) mainContent.classList.remove('expanded');
            if (toggleIcon) {
              toggleIcon.classList.remove('bi-chevron-right');
              toggleIcon.classList.add('bi-chevron-left');
            }
          }
        }

        applyState(localStorage.getItem('sidebarCollapsed') === 'true');

        var btn = document.getElementById('sidebar-toggle');
        if (btn) {
          btn.addEventListener('click', function () {
            var isCollapsed = sidebar.classList.contains('collapsed');
            applyState(!isCollapsed);
            localStorage.setItem('sidebarCollapsed', String(!isCollapsed));
          });
        }
      })();

      document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('form').forEach(function (form) {
          form.addEventListener('submit', function () {
            if (this.checkValidity()) {
              var btn = this.querySelector('[type="submit"]');
              if (btn && !btn.dataset.noLoading) {
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>Procesando...';
              }
            }
          });
        });
      });
    block scripts
