doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title TodoStock S.A.
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css")
    script(src="https://unpkg.com/htmx.org@2.0.4/dist/htmx.min.js", defer)
    style.
      .sidebar {
        width: 240px;
        min-height: 100vh;
        position: fixed;
        top: 0;
        left: 0;
        z-index: 100;
        overflow: hidden;
        transition: width 0.22s ease;
      }
      .sidebar.collapsed { width: 64px; }

      .sidebar .sidebar-text { white-space: nowrap; }
      .sidebar.collapsed .sidebar-text { display: none; }

      .sidebar .nav-link {
        color: rgba(255, 255, 255, .65);
        border-radius: 6px;
        padding: .5rem .75rem;
        font-size: .925rem;
        display: flex;
        align-items: center;
        white-space: nowrap;
      }
      .sidebar .nav-link:hover { color: #fff; background-color: rgba(255, 255, 255, .1); }
      .sidebar .nav-link.active { color: #fff; background-color: rgba(255, 255, 255, .15); font-weight: 600; }
      .sidebar.collapsed .nav-link { justify-content: center; padding: .5rem; }

      .sidebar-toggle-btn {
        background: none;
        border: none;
        color: rgba(255,255,255,.55);
        cursor: pointer;
        padding: .2rem .4rem;
        border-radius: 4px;
        line-height: 1;
        flex-shrink: 0;
      }
      .sidebar-toggle-btn:hover { color: #fff; background: rgba(255,255,255,.12); }

      .sidebar.collapsed .sidebar-brand-area { display: none !important; }
      .sidebar.collapsed .sidebar-header { justify-content: center; }

      .main-content {
        flex: 1;
        margin-left: 240px;
        min-height: 100vh;
        min-width: 0;
        transition: margin-left 0.22s ease;
      }
      .main-content.expanded { margin-left: 64px; }

      .main-content .container {
        max-width: 100% !important;
        width: 100% !important;
        padding-left: 1.75rem;
        padding-right: 1.75rem;
      }

      .status-pill,
      .entity-pill {
        display: inline-flex;
        align-items: center;
        gap: .25rem;
        border-radius: 999px;
        padding: .35rem .7rem;
        font-size: .78rem;
        font-weight: 700;
        letter-spacing: .01em;
      }

      .status-attention {
        background: #fff3cd;
        color: #7a4b00;
        border: 1px solid #f6d68a;
      }

      .status-progress {
        background: #e1effe;
        color: #114a78;
        border: 1px solid #b8d7f5;
      }

      .status-done {
        background: #dcf5e7;
        color: #17603a;
        border: 1px solid #b9e8cd;
      }

      .status-cancelled {
        background: #fde2e4;
        color: #8c2331;
        border: 1px solid #f5bcc4;
      }

      .status-neutral {
        background: #edf1f5;
        color: #475467;
        border: 1px solid #d8e0e8;
      }

      .entity-purchase {
        background: #eaf2ff;
        color: #1d4f91;
        border: 1px solid #c8daf8;
      }

      .entity-sale {
        background: #e7f8f2;
        color: #116149;
        border: 1px solid #c3eadc;
      }

      .entity-payment {
        background: #ebe9ff;
        color: #4a3fa1;
        border: 1px solid #d1cbfa;
      }

      .entity-collection {
        background: #e8f7ee;
        color: #1e6a48;
        border: 1px solid #c6e8d3;
      }
  body
    if activeTab
      - const currentRole = currentUser && currentUser.role ? currentUser.role : null
      - const canAccessCommercial = currentRole === 'ADMIN' || currentRole === 'COMMERCIAL' || currentRole === 'VENDOR' || currentRole === 'CLIENT'
      - const canAccessInventory = currentRole === 'ADMIN' || currentRole === 'INVENTORY'
      - const canAccessFinance = currentRole === 'ADMIN' || currentRole === 'FINANCE'
      .d-flex
        nav.sidebar.bg-dark.d-flex.flex-column.p-3
          .sidebar-header.d-flex.align-items-center.justify-content-between.mb-4
            .sidebar-brand-area.d-flex.align-items-center.overflow-hidden
              i.bi.bi-boxes.text-white.fs-5.flex-shrink-0
              span.sidebar-text.fw-bold.fs-6.text-white.ms-2 TodoStock S.A.
            button.sidebar-toggle-btn#sidebar-toggle(type="button", title="Colapsar menú")
              i#toggle-icon.bi.bi-chevron-left

          ul.nav.nav-pills.flex-column.gap-1.flex-grow-1
            if canAccessCommercial
              li.nav-item
                a.nav-link(class=activeTab === 'clients' ? 'active' : '', href="/api/clients", title="Clientes")
                  i.bi.bi-people-fill.flex-shrink-0
                  span.sidebar-text.ms-2 Clientes
              li.nav-item
                a.nav-link(class=activeTab === 'vendors' ? 'active' : '', href="/api/vendors", title="Proveedores")
                  i.bi.bi-truck.flex-shrink-0
                  span.sidebar-text.ms-2 Proveedores
              li.nav-item
                a.nav-link(class=activeTab === 'products' ? 'active' : '', href="/api/products", title="Productos")
                  i.bi.bi-box-seam.flex-shrink-0
                  span.sidebar-text.ms-2 Productos
              li.nav-item
                a.nav-link(class=activeTab === 'orders' ? 'active' : '', href="/api/orders?type=PURCHASE", title="Órdenes")
                  i.bi.bi-cart-check.flex-shrink-0
                  span.sidebar-text.ms-2 Órdenes
            if canAccessInventory
              li.nav-item
                a.nav-link(class=activeTab === 'inventory' ? 'active' : '', href="/api/inventory", title="Inventario")
                  i.bi.bi-archive.flex-shrink-0
                  span.sidebar-text.ms-2 Inventario
              if currentRole === 'INVENTORY'
                li.nav-item.ms-3
                  a.nav-link(class=activeTab === 'inventory' && inventoryTab === 'purchase' ? 'active' : '', href="/api/inventory?tab=purchase", title="Recepción y auditoría")
                    i.bi.bi-arrow-down-left-circle.flex-shrink-0
                    span.sidebar-text.ms-2 Recepción y auditoría
                li.nav-item.ms-3
                  a.nav-link(class=activeTab === 'inventory' && inventoryTab === 'sale' ? 'active' : '', href="/api/inventory?tab=sale", title="Armado y despacho")
                    i.bi.bi-arrow-up-right-circle.flex-shrink-0
                    span.sidebar-text.ms-2 Armado y despacho
                li.nav-item.ms-3
                  a.nav-link(class=activeTab === 'inventory' && inventoryTab === 'stock' ? 'active' : '', href="/api/inventory?tab=stock", title="Stock total")
                    i.bi.bi-box-seam.flex-shrink-0
                    span.sidebar-text.ms-2 Stock total
            if canAccessFinance
              li.nav-item
                a.nav-link(class=activeTab === 'transactions' ? 'active' : '', href="/api/transactions?type=PAYMENT", title="Finanzas")
                  i.bi.bi-cash-coin.flex-shrink-0
                  span.sidebar-text.ms-2 Finanzas
              if currentRole === 'FINANCE'
                li.nav-item.ms-3
                  a.nav-link(class=activeTab === 'transactions' && activeType === 'PAYMENT' ? 'active' : '', href="/api/transactions?type=PAYMENT", title="Órdenes de Pago")
                    i.bi.bi-credit-card.flex-shrink-0
                    span.sidebar-text.ms-2 Órdenes de Pago
                li.nav-item.ms-3
                  a.nav-link(class=activeTab === 'transactions' && activeType === 'COLLECTION' ? 'active' : '', href="/api/transactions?type=COLLECTION", title="Órdenes de Cobro")
                    i.bi.bi-cash-stack.flex-shrink-0
                    span.sidebar-text.ms-2 Órdenes de Cobro

          .mt-auto
            form(action="/api/auth/logout", method="POST")
              button.btn.btn-outline-light.btn-sm.w-100(type="submit", title="Cerrar sesión")
                i.bi.bi-box-arrow-right.flex-shrink-0
                span.sidebar-text.ms-1 Cerrar sesión

        main.main-content.bg-light
          block content

    else
      block content

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
    if currentUser
      script(src="/socket.io/socket.io.js")
    script.
      (function () {
        window.formatCurrency = function (value) {
          return new Intl.NumberFormat('es-AR', {
            style: 'currency',
            currency: 'ARS',
            minimumFractionDigits: 2,
            maximumFractionDigits: 2,
          }).format(Number(value || 0));
        };

        var sidebar = document.querySelector('.sidebar');
        var mainContent = document.querySelector('.main-content');
        var toggleIcon = document.getElementById('toggle-icon');

        function applyState(collapsed) {
          if (!sidebar) return;
          if (collapsed) {
            sidebar.classList.add('collapsed');
            if (mainContent) mainContent.classList.add('expanded');
            if (toggleIcon) {
              toggleIcon.classList.remove('bi-chevron-left');
              toggleIcon.classList.add('bi-chevron-right');
            }
          } else {
            sidebar.classList.remove('collapsed');
            if (mainContent) mainContent.classList.remove('expanded');
            if (toggleIcon) {
              toggleIcon.classList.remove('bi-chevron-right');
              toggleIcon.classList.add('bi-chevron-left');
            }
          }
        }

        applyState(localStorage.getItem('sidebarCollapsed') === 'true');

        var btn = document.getElementById('sidebar-toggle');
        if (btn) {
          btn.addEventListener('click', function () {
            var isCollapsed = sidebar.classList.contains('collapsed');
            applyState(!isCollapsed);
            localStorage.setItem('sidebarCollapsed', String(!isCollapsed));
          });
        }
      })();

      document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('form').forEach(function (form) {
          form.addEventListener('submit', function () {
            if (this.checkValidity()) {
              var btn = this.querySelector('[type="submit"]');
              if (btn && !btn.dataset.noLoading) {
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>Procesando...';
              }
            }
          });
        });

        var realtimeRole = !{JSON.stringify((currentUser && currentUser.role) ? currentUser.role : null)};

        if (typeof io !== 'function' || !realtimeRole) {
          return;
        }

        var toastContainer = document.getElementById('realtime-toast-container');

        if (!toastContainer) {
          toastContainer = document.createElement('div');
          toastContainer.id = 'realtime-toast-container';
          toastContainer.className = 'toast-container position-fixed top-0 end-0 p-3';
          toastContainer.style.zIndex = '1085';
          document.body.appendChild(toastContainer);
        }

        function showRealtimeToast(notification) {
          if (!notification || !notification.title || !window.bootstrap || !toastContainer) {
            return;
          }

          var wrapper = document.createElement('div');
          wrapper.className = 'toast border-0 shadow-sm';
          wrapper.setAttribute('role', 'alert');
          wrapper.setAttribute('aria-live', 'assertive');
          wrapper.setAttribute('aria-atomic', 'true');

          var linkHtml = notification.link
            ? '<div class="mt-2 pt-2 border-top"><a class="btn btn-sm btn-primary" href="' + notification.link + '">Ver detalle</a></div>'
            : '';

          wrapper.innerHTML = '' +
            '<div class="toast-header">' +
              '<i class="bi bi-bell-fill text-primary me-2"></i>' +
              '<strong class="me-auto">' + notification.title + '</strong>' +
              '<small>Ahora</small>' +
              '<button type="button" class="btn-close ms-2 mb-1" data-bs-dismiss="toast" aria-label="Cerrar"></button>' +
            '</div>' +
            '<div class="toast-body">' +
              '<div>' + notification.message + '</div>' +
              linkHtml +
            '</div>';

          toastContainer.appendChild(wrapper);

          var toast = new window.bootstrap.Toast(wrapper, {
            delay: 7000,
          });

          wrapper.addEventListener('hidden.bs.toast', function () {
            wrapper.remove();
          });

          toast.show();
        }

        var socket = io({
          withCredentials: true,
          transports: ['websocket', 'polling'],
        });

        socket.on('domain:notification', function (notification) {
          showRealtimeToast(notification);
        });

        socket.on('connect_error', function (error) {
          console.warn('No se pudo conectar el canal realtime:', error.message);
        });
      });
    block scripts
