extends ../layout

block content
  .container.mt-5
    .d-flex.justify-content-between.align-items-center.mb-3
      h2 Nueva Transacción
      a.btn.btn-outline-secondary(href="/api/transactions") Volver al listado

    if errorMessage
      .alert.alert-danger.alert-dismissible.fade.show
        i.bi.bi-exclamation-triangle-fill.me-2
        = errorMessage
        button.btn-close(type="button", data-bs-dismiss="alert", aria-label="Cerrar")

    if !orders || orders.length === 0
      .alert.alert-warning No hay órdenes registradas para asociar a una transacción.

    else
      .row.justify-content-center
        .col-md-6
          .card.shadow
            .card-header.bg-dark.text-white
              h4.mb-0 Datos de la transacción
            .card-body
              form(action="/api/transactions", method="POST")

                .mb-3
                  label.form-label Tipo de transacción
                  select.form-select(name="transaction_type", required, onchange="filterOrders(this.value)")
                    option(value="") Seleccionar tipo
                    option(value="PAYMENT") Orden de Pago (compra al proveedor)
                    option(value="COLLECTION") Orden de Cobro (venta al cliente)

                .mb-3
                  label.form-label Orden asociada
                  select.form-select#order-select(name="order_id", required)
                    option(value="") Seleccionar orden
                    each order in orders
                      option(
                        value=order.id,
                        data-type=order.order_type
                      )= `#${order.id.slice(-6).toUpperCase()} — ${order.order_type === 'PURCHASE' ? 'Compra' : 'Venta'} — ${order.status}`

                .d-flex.justify-content-between.mt-4
                  a.btn.btn-secondary(href="/api/transactions") Cancelar
                  button.btn.btn-dark(type="submit") Crear Transacción

  script.
    function filterOrders(type) {
      const select = document.getElementById('order-select');
      const options = select.querySelectorAll('option[data-type]');
      const expectedOrderType = type === 'PAYMENT' ? 'PURCHASE' : 'SALE';

      options.forEach(opt => {
        opt.style.display = (!type || opt.dataset.type === expectedOrderType) ? '' : 'none';
      });

      select.value = '';
    }
