extends ../layout

block content
  .container.mt-5

    if errorMessage
      .alert.alert-danger.alert-dismissible.fade.show
        i.bi.bi-exclamation-triangle-fill.me-2
        = errorMessage
        button.btn-close(type="button", data-bs-dismiss="alert", aria-label="Cerrar")
      a.btn.btn-secondary(href='/api/transactions?type=PAYMENT') Volver al listado

    else if transaction
      - const transactionItems = transaction.items && transaction.items.length > 0 ? transaction.items : (order ? order.items : [])
      - const transactionTotal = typeof transaction.total_amount === 'number' ? transaction.total_amount : (order ? order.total_amount : 0)
      if flashError
        .alert.alert-warning.alert-dismissible.fade.show
          i.bi.bi-exclamation-triangle-fill.me-2
          = flashError
          button.btn-close(type="button", data-bs-dismiss="alert", aria-label="Cerrar")

      .d-flex.justify-content-between.align-items-center.mb-3
        h2
          span.entity-pill.me-2(class=transaction.transaction_type === 'PAYMENT' ? 'entity-payment' : 'entity-collection')
            = typeLabel
          | Transacción ##{transaction.id.slice(-6).toUpperCase()}
        a.btn.btn-outline-secondary(href=transaction.transaction_type === 'COLLECTION' ? '/api/transactions?type=COLLECTION' : '/api/transactions?type=PAYMENT') Volver al listado

      .row.mb-4
        .col-md-8
          .card.shadow-sm
            .card-header.bg-light
              strong Información general
            .card-body
              .row
                .col-md-6
                  p
                    strong Estado:&nbsp;
                    span.status-pill(class=`status-${statusBadge}`) #{statusLabel}
                  p
                    strong Orden asociada:&nbsp;
                    a(href=`/api/orders/${transaction.order_id}`)
                      = `#${transaction.order_id.slice(-6).toUpperCase()}`
                  p
                    strong Creada:&nbsp;
                    = new Date(transaction.created_at).toLocaleDateString('es-AR')
                .col-md-6
                  if transaction.pos_number
                    p
                      strong Nro. POS:&nbsp;
                      = transaction.pos_number
                  if transaction.document_number
                    p
                      strong Nro. Documento:&nbsp;
                      = transaction.document_number

          if order
            .card.shadow-sm.mt-4
              .card-header.bg-light
                strong= transaction.transaction_type === 'PAYMENT' ? 'Detalle de lo que se paga' : 'Detalle de lo que se cobra'
              .card-body
                .d-flex.justify-content-between.align-items-start.gap-3.flex-wrap.mb-3
                  div
                    p.mb-1
                      strong Orden:&nbsp;
                      a(href=`/api/orders/${order.id}`)= `#${order.id.slice(-6).toUpperCase()}`
                    p.mb-0.text-muted= `${order.items.length} ítem${order.items.length === 1 ? '' : 's'} asociados`
                  .text-end
                    p.mb-1
                      strong Total:&nbsp;
                      = formatCurrency(transactionTotal)
                    p.mb-0.text-muted= transaction.transaction_type === 'PAYMENT' ? 'Monto total a pagar' : 'Monto total a cobrar'

                .table-responsive
                  table.table.table-sm.table-bordered.mb-0
                    thead.table-light
                      tr
                        th Producto
                        th.text-center Cantidad
                        th.text-end Precio unitario
                        th.text-end Subtotal
                    tbody
                      each item in transactionItems
                        tr
                          td= item.product_name
                          td.text-center= item.quantity
                          td.text-end= formatCurrency(item.unit_price)
                          td.text-end= formatCurrency(item.quantity * item.unit_price)

        .col-md-4
          .card.shadow-sm
            .card-header.bg-light
              strong Acciones
            .card-body.d-grid.gap-2

              if transaction.transaction_type === 'PAYMENT'
                if order
                  if (order.status === 'TO_VERIFY_BUDGET' || order.status === 'PENDING_BUDGET') && (transaction.status === 'TO_VERIFY' || transaction.status === 'PENDING')
                    form(action=`/api/orders/purchase/${order.id}/verify-budget`, method="POST")
                      input(type="hidden", name="transaction_id", value=transaction.id)
                      button.btn.btn-primary.w-100(type="submit")
                        i.bi.bi-check-circle.me-1
                        | Confirmar presupuesto

                  if transaction.status !== 'VERIFIED' && (order.status === 'TO_VERIFY_BUDGET' || order.status === 'PENDING_BUDGET' || order.status === 'TO_CONFIRM' || order.status === 'CONFIRMED')
                    form(action=`/api/orders/purchase/${order.id}/cancel`, method="POST", onsubmit="return confirm('¿Confirmás la cancelación de esta orden? Esta acción no se puede deshacer.')")
                      button.btn.btn-outline-danger.w-100(type="submit")
                        i.bi.bi-x-circle.me-1
                        | Cancelar orden

                  if transaction.status === 'PENDING_PAYMENT' && order.status === 'AUDITED'
                    form(action=`/api/transactions/${transaction.id}/complete`, method="POST")
                      .mb-2
                        input.form-control.form-control-sm(
                          type="text",
                          name="pos_number",
                          placeholder="Ej: 0001",
                          required,
                          maxlength="20",
                          pattern="[A-Za-z0-9-]{1,20}",
                          title="Solo letras, números y guiones (máx. 20 caracteres)"
                        )
                      .mb-2
                        input.form-control.form-control-sm(
                          type="text",
                          name="document_number",
                          placeholder="Ej: 00010001",
                          required,
                          maxlength="20",
                          pattern="[0-9]{1,20}",
                          title="Solo números (máx. 20 dígitos)"
                        )
                      button.btn.btn-success.w-100(type="submit")
                        i.bi.bi-cash-coin.me-1
                        | Registrar pago

                  if transaction.status === 'VERIFIED'
                    p.text-muted.mb-0.text-center Sin acciones disponibles

                  if transaction.status !== 'VERIFIED' && order.status !== 'TO_VERIFY_BUDGET' && order.status !== 'PENDING_BUDGET' && order.status !== 'TO_CONFIRM' && order.status !== 'CONFIRMED' && !(transaction.status === 'PENDING_PAYMENT' && order.status === 'AUDITED')
                    p.text-muted.mb-0.text-center Sin acciones disponibles
                else
                  p.text-muted.mb-0.text-center Sin información de orden disponible

              else if transaction.transaction_type === 'COLLECTION'
                if order && (order.status === 'TO_VERIFY_COLLECTION' || order.status === 'PENDING_PAYMENT') && (transaction.status === 'PENDING' || transaction.status === 'TO_VERIFY')
                  form(action=`/api/orders/sale/${order.id}/confirm-payment`, method="POST")
                    button.btn.btn-success.w-100(type="submit")
                      i.bi.bi-check-circle.me-1
                      | Confirmar cobro
                  form(action=`/api/orders/sale/${order.id}/cancel`, method="POST", onsubmit="return confirm('¿Confirmás la cancelación de esta orden? Esta acción no se puede deshacer.')")
                    button.btn.btn-outline-danger.w-100(type="submit")
                      i.bi.bi-x-circle.me-1
                      | Cancelar orden
                else
                  p.text-muted.mb-0.text-center Sin acciones disponibles
