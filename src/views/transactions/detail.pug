extends ../layout

block content
  .container.mt-5

    if errorMessage
      .alert.alert-danger= errorMessage
      a.btn.btn-secondary(href="/api/transactions") Volver al listado

    else if transaction
      .d-flex.justify-content-between.align-items-center.mb-3
        h2
          span.badge.me-2(class=transaction.transaction_type === 'PAYMENT' ? 'bg-primary' : 'bg-success')
            = typeLabel
          | Transacción ##{transaction.id.slice(-6).toUpperCase()}
        a.btn.btn-outline-secondary(href="/api/transactions") Volver al listado

      .row.mb-4
        .col-md-8
          .card.shadow-sm
            .card-header.bg-light
              strong Información general
            .card-body
              .row
                .col-md-6
                  p
                    strong Estado:&nbsp;
                    span.badge(class=`bg-${statusBadge}`) #{statusLabel}
                  p
                    strong Orden asociada:&nbsp;
                    a(href=`/api/orders/${transaction.order_id}`)
                      = `#${transaction.order_id.slice(-6).toUpperCase()}`
                  p
                    strong Creada:&nbsp;
                    = new Date(transaction.created_at).toLocaleDateString('es-AR')
                .col-md-6
                  if transaction.pos_number
                    p
                      strong Nro. POS:&nbsp;
                      = transaction.pos_number
                  if transaction.document_number
                    p
                      strong Nro. Documento:&nbsp;
                      = transaction.document_number

        .col-md-4
          .card.shadow-sm
            .card-header.bg-light
              strong Acciones
            .card-body.d-grid.gap-2

              if transaction.status === 'PENDING'

                if transaction.transaction_type === 'PAYMENT'
                  form(action=`/api/transactions/${transaction.id}/complete`, method="POST")
                    .mb-2
                      input.form-control.form-control-sm(
                        type="text",
                        name="pos_number",
                        placeholder="Número de POS",
                        required
                      )
                    .mb-2
                      input.form-control.form-control-sm(
                        type="text",
                        name="document_number",
                        placeholder="Número de documento",
                        required
                      )
                    button.btn.btn-success.w-100(type="submit") Registrar pago

                else
                  form(action=`/api/transactions/${transaction.id}/complete`, method="POST")
                    button.btn.btn-success.w-100(type="submit") Confirmar cobro

                form(action=`/api/transactions/${transaction.id}/cancel`, method="POST")
                  button.btn.btn-outline-danger.w-100(type="submit") Cancelar transacción

              else
                p.text-muted.mb-0.text-center Sin acciones disponibles
