extends ../layout

block content

  if errorMessage
    .flash.flash-err
      i.bi.bi-exclamation-triangle-fill(style="flex-shrink:0")
      span= errorMessage
    a.btn.btn-secondary(href='/api/transactions?type=PAYMENT' style="margin-bottom:1rem") Volver

  else if transaction
    - const transactionItems = transaction.items && transaction.items.length > 0 ? transaction.items : (order ? order.items : [])
    - const transactionTotal = typeof transaction.total_amount === 'number' ? transaction.total_amount : (order ? order.total_amount : 0)

    if flashError
      .flash.flash-warn
        i.bi.bi-exclamation-triangle-fill(style="flex-shrink:0")
        span= flashError

    .pg-header
      div
        .flex-gap
          span.entity-pill(class=transaction.transaction_type === 'PAYMENT' ? 'entity-payment' : 'entity-collection')
            = typeLabel
          h1.pg-title Transacción ##{transaction.id.slice(-6).toUpperCase()}
      .pg-actions
        a.btn.btn-secondary(href=transaction.transaction_type === 'COLLECTION' ? '/api/transactions?type=COLLECTION' : '/api/transactions?type=PAYMENT') Volver

    .grid-2-3
      div
        .crd(style="margin-bottom:1.25rem")
          .crd-head
            p.crd-title Información general
          .crd-body
            .grid-2
              div
                .info-row
                  span.info-lbl Estado:
                  span.status-pill(class=`status-${statusBadge}` style="margin-left:0.5rem") #{statusLabel}
                .info-row
                  span.info-lbl Orden:
                  a(href=`/api/orders/${transaction.order_id}` style="font-size:0.875rem;font-weight:600")
                    = `#${transaction.order_id.slice(-6).toUpperCase()}`
                .info-row
                  span.info-lbl Creada:
                  span.info-val= new Date(transaction.created_at).toLocaleDateString('es-AR')
              div
                if transaction.pos_number
                  .info-row
                    span.info-lbl Nro. POS:
                    span.info-val= transaction.pos_number
                if transaction.document_number
                  .info-row
                    span.info-lbl Nro. Doc:
                    span.info-val= transaction.document_number

        if order
          .crd
            .crd-head
              p.crd-title= transaction.transaction_type === 'PAYMENT' ? 'Detalle de lo que se paga' : 'Detalle de lo que se cobra'
            .crd-body(style="padding:0")
              table.tbl.tbl-sm
                thead
                  tr
                    th Producto
                    th(style="text-align:center") Cantidad
                    th(style="text-align:right") Precio unit.
                    th(style="text-align:right") Subtotal
                tbody
                  each item in transactionItems
                    tr
                      td= item.product_name
                      td(style="text-align:center")= item.quantity
                      td(style="text-align:right")= formatCurrency(item.unit_price)
                      td(style="text-align:right")= formatCurrency(item.quantity * item.unit_price)
                tfoot
                  tr
                    td(colspan="3" style="text-align:right;padding:0.65rem 1rem;background:#0f172a;color:#fff;font-weight:700") Total
                    td(style="text-align:right;padding:0.65rem 1rem;background:#0f172a;color:#fff;font-weight:700")= formatCurrency(transactionTotal)

      .crd
        .crd-head
          p.crd-title Acciones
        .crd-body(style="display:flex;flex-direction:column;gap:0.75rem")

          if transaction.transaction_type === 'PAYMENT'
            if order
              if (order.status === 'TO_VERIFY_BUDGET' || order.status === 'PENDING_BUDGET') && (transaction.status === 'TO_VERIFY' || transaction.status === 'PENDING')
                form(action=`/api/orders/purchase/${order.id}/verify-budget`, method="POST")
                  input(type="hidden", name="transaction_id", value=transaction.id)
                  button.btn.btn-primary.w-100(type="submit")
                    i.bi.bi-check-circle
                    | Confirmar presupuesto

              if transaction.status !== 'VERIFIED' && (order.status === 'TO_VERIFY_BUDGET' || order.status === 'PENDING_BUDGET' || order.status === 'TO_CONFIRM' || order.status === 'CONFIRMED')
                form(action=`/api/orders/purchase/${order.id}/cancel`, method="POST", onsubmit="return confirm('¿Confirmás la cancelación de esta orden? Esta acción no se puede deshacer.')")
                  button.btn.btn-danger.w-100(type="submit")
                    i.bi.bi-x-circle
                    | Cancelar orden

              if transaction.status === 'PENDING_PAYMENT' && order.status === 'AUDITED'
                form(action=`/api/transactions/${transaction.id}/complete`, method="POST")
                  p(style="font-size:0.8rem;color:#64748b;margin:0 0 0.5rem") Se registrará el pago al proveedor por el monto auditado.
                  button.btn.btn-success.w-100(type="submit")
                    i.bi.bi-cash-coin
                    | Registrar pago

              if transaction.status === 'VERIFIED'
                p(style="color:#94a3b8;font-size:0.875rem;text-align:center;margin:0") Sin acciones disponibles

              if transaction.status !== 'VERIFIED' && order.status !== 'TO_VERIFY_BUDGET' && order.status !== 'PENDING_BUDGET' && order.status !== 'TO_CONFIRM' && order.status !== 'CONFIRMED' && !(transaction.status === 'PENDING_PAYMENT' && order.status === 'AUDITED')
                p(style="color:#94a3b8;font-size:0.875rem;text-align:center;margin:0") Sin acciones disponibles
            else
              p(style="color:#94a3b8;font-size:0.875rem;text-align:center;margin:0") Sin información de orden disponible

          else if transaction.transaction_type === 'COLLECTION'
            if order && (order.status === 'TO_VERIFY_COLLECTION' || order.status === 'PENDING_PAYMENT') && (transaction.status === 'PENDING' || transaction.status === 'TO_VERIFY')
              form(action=`/api/orders/sale/${order.id}/confirm-payment`, method="POST")
                p(style="font-size:0.8rem;color:#64748b;margin:0 0 0.5rem") Al confirmar se emitirá el comprobante de cobro con punto de venta 0001.
                button.btn.btn-success.w-100(type="submit")
                  i.bi.bi-check-circle
                  | Confirmar cobro
              form(action=`/api/orders/sale/${order.id}/cancel`, method="POST", onsubmit="return confirm('¿Confirmás la cancelación de esta orden? Esta acción no se puede deshacer.')")
                button.btn.btn-danger.w-100(type="submit")
                  i.bi.bi-x-circle
                  | Cancelar orden
            else
              p(style="color:#94a3b8;font-size:0.875rem;text-align:center;margin:0") Sin acciones disponibles
