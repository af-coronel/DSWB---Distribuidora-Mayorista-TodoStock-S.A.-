extends ../layout

block content
  .crd(style="max-width:440px;margin:4rem auto;text-align:center")
    .crd-body(style="padding:3rem 2rem")
      i.bi.bi-search(style="font-size:2.5rem;color:#cbd5e1;margin-bottom:1rem;display:block")
      h1(style="font-family:'Sora',sans-serif;font-size:3rem;font-weight:800;color:#0f172a;margin:0 0 0.5rem") 404
      h2(style="font-size:1.1rem;font-weight:600;color:#475569;margin:0 0 0.75rem") Página no encontrada
      p(style="font-size:0.875rem;color:#64748b;margin:0 0 1.5rem")
        | La página que buscás no existe o fue movida.
        br
        | Revisá la URL o volvé al inicio.
      a.btn.btn-primary(href="/")
        i.bi.bi-box-arrow-in-right
        | Ir al inicio de sesión
