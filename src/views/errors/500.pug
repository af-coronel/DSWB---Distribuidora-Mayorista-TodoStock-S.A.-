extends ../layout

block content
  .crd(style="max-width:480px;margin:4rem auto;text-align:center")
    .crd-body(style="padding:3rem 2rem")
      i.bi.bi-exclamation-triangle(style="font-size:2.5rem;color:#f87171;margin-bottom:1rem;display:block")
      h1(style="font-family:'Sora',sans-serif;font-size:3rem;font-weight:800;color:#0f172a;margin:0 0 0.5rem") 500
      h2(style="font-size:1.1rem;font-weight:600;color:#475569;margin:0 0 0.75rem") Error interno del servidor
      if errorMessage
        .flash.flash-warn(style="text-align:left;margin-bottom:1.25rem")
          i.bi.bi-info-circle(style="flex-shrink:0")
          span= errorMessage
      else
        p(style="font-size:0.875rem;color:#64748b;margin:0 0 1.5rem")
          | Algo salió mal de nuestro lado.
          br
          | Intentá de nuevo en unos minutos.
      a.btn.btn-primary(href="/api/clients")
        i.bi.bi-house
        | Volver al inicio
