extends ../layout

block content
  .container.mt-5

    if errorMessage
      .alert.alert-danger= errorMessage
      a.btn.btn-secondary(href="/api/orders") Volver al listado

    else if order
      .d-flex.justify-content-between.align-items-center.mb-3
        h2 Auditoría — Orden ##{order.id.slice(-6).toUpperCase()}
        a.btn.btn-outline-secondary(href=`/api/orders/${order.id}`) Volver al detalle

      .alert.alert-info
        i.bi.bi-info-circle.me-2
        | Revisá cada ítem e informá la cantidad recibida en buen estado. El total de la orden de pago se recalculará automáticamente.

      .card.shadow
        .card-header.bg-dark.text-white
          strong Ítems recibidos
        .card-body
          form(action=`/api/orders/purchase/${order.id}/audit`, method="POST")
            table.table.table-bordered.mb-4
              thead.table-light
                tr
                  th Producto
                  th.text-center Cantidad pedida
                  th.text-center Cantidad recibida en buen estado
                  th Fecha de vencimiento (opcional)
              tbody
                each item, index in order.items
                  tr
                    td
                      = item.product_name
                      input(type="hidden", name=`items[${index}][product_id]`, value=item.product_id)
                    td.text-center= item.quantity
                    td.text-center
                      input.form-control.form-control-sm.text-center(
                        type="number"
                        name=`items[${index}][received_quantity]`
                        value=item.quantity
                        min="0"
                        max=item.quantity
                        required
                      )
                    td
                      input.form-control.form-control-sm(
                        type="date"
                        name=`items[${index}][expiration_date]`
                      )

            .d-flex.justify-content-between
              a.btn.btn-secondary(href=`/api/orders/${order.id}`) Cancelar
              button.btn.btn-warning(type="submit")
                i.bi.bi-check2-circle.me-1
                | Confirmar auditoría y registrar stock
