extends ../layout

block content
  .container.mt-5

    if errorMessage
      .alert.alert-danger.alert-dismissible.fade.show
        i.bi.bi-exclamation-triangle-fill.me-2
        = errorMessage
        button.btn-close(type="button", data-bs-dismiss="alert", aria-label="Cerrar")
      a.btn.btn-secondary(href=order?.order_type === 'SALE' ? '/api/orders?type=SALE' : '/api/orders?type=PURCHASE') Volver al listado

    else if order
      if flashError
        .alert.alert-warning.alert-dismissible.fade.show
          i.bi.bi-exclamation-triangle-fill.me-2
          = flashError
          button.btn-close(type="button", data-bs-dismiss="alert", aria-label="Cerrar")

      .d-flex.justify-content-between.align-items-center.mb-3
        h2
          span.entity-pill.me-2(class=order.order_type === 'PURCHASE' ? 'entity-purchase' : 'entity-sale')
            = order.order_type === 'PURCHASE' ? 'Compra' : 'Venta'
          | Orden ##{order.id.slice(-6).toUpperCase()}
        a.btn.btn-outline-secondary(href=order.order_type === 'SALE' ? '/api/orders?type=SALE' : '/api/orders?type=PURCHASE') Volver al listado

      .row.mb-4
        .col-md-8
          .card.shadow-sm
            .card-header.bg-light
              strong Información general
            .card-body
              .row
                .col-md-6
                  p
                    strong Estado:&nbsp;
                    span.status-pill(class=`status-${statusBadge}`) #{statusLabel}
                  p
                    strong Socio:&nbsp;
                    = partnerName
                  p
                    strong CUIT:&nbsp;
                    = order.partner_cuit
                .col-md-6
                  p
                    strong Total:&nbsp;
                    = `$ ${order.total_amount.toFixed(2)}`
                  p
                    strong Creada:&nbsp;
                    = new Date(order.created_at).toLocaleDateString('es-AR')
                  if order.scheduled_date
                    p
                      strong Fecha programada:&nbsp;
                      = new Date(order.scheduled_date).toLocaleDateString('es-AR')
              if order.notes
                p
                  strong Notas:&nbsp;
                  = order.notes

        .col-md-4
          .card.shadow-sm
            .card-header.bg-light
              strong Acciones
            .card-body.d-grid.gap-2

              if order.order_type === 'PURCHASE'
                if order.status === 'TO_VERIFY_BUDGET' || order.status === 'PENDING_BUDGET'
                  .alert.alert-info.mb-0.small
                    i.bi.bi-info-circle.me-1
                    | La confirmación del presupuesto y la cancelación se gestionan desde&nbsp;
                    a(href="/api/transactions") Finanzas
                    | .
                else if order.status === 'TO_CONFIRM'
                  form(action=`/api/orders/purchase/${order.id}/confirm`, method="POST")
                    button.btn.btn-primary.w-100(type="submit") Confirmar orden (mail proveedor)
                else if order.status === 'CONFIRMED' || order.status === 'RECEIVED'
                  .alert.alert-info.mb-0.small
                    i.bi.bi-box-seam.me-1
                    | La recepción y auditoría se gestionan desde&nbsp;
                    a(href="/api/inventory?tab=purchase") Inventario
                    | .
                else
                  p.text-muted.mb-0.text-center Sin acciones disponibles

              else if order.order_type === 'SALE'
                if order.status === 'TO_VERIFY_COLLECTION' || order.status === 'PENDING_PAYMENT'
                  .alert.alert-info.mb-0.small
                    i.bi.bi-info-circle.me-1
                    | La confirmación del cobro y la cancelación se gestionan desde&nbsp;
                    a(href="/api/transactions") Finanzas
                    | .
                else if order.status === 'PENDING_ASSEMBLY' || order.status === 'DISPATCHING'
                  .alert.alert-info.mb-0.small
                    i.bi.bi-box-seam.me-1
                    | El armado y despacho se gestionan desde&nbsp;
                    a(href="/api/inventory?tab=sale") Inventario
                    | .
                else
                  p.text-muted.mb-0.text-center Sin acciones disponibles

      .card.shadow-sm
        .card-header.bg-light
          strong Ítems de la orden
        .card-body
          table.table.table-bordered.mb-0
            thead.table-light
              tr
                th Producto
                th.text-center Cantidad
                th.text-end Precio unitario
                th.text-end Subtotal
            tbody
              each item in order.items
                tr
                  td= item.product_name
                  td.text-center= item.quantity
                  td.text-end= `$ ${item.unit_price.toFixed(2)}`
                  td.text-end= `$ ${(item.quantity * item.unit_price).toFixed(2)}`
            tfoot
              tr.table-dark
                td(colspan="3")
                  strong Total
                td.text-end
                  strong= `$ ${order.total_amount.toFixed(2)}`
