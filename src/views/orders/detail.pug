extends ../layout

block content
  .container.mt-5
    - const canAccessFinanceView = !!canAccessFinance

  if errorMessage
    .flash.flash-err
      i.bi.bi-exclamation-triangle-fill(style="flex-shrink:0")
      span= errorMessage
    a.btn.btn-secondary(href='/api/orders?type=PURCHASE' style="margin-bottom:1rem") Volver al listado

  else if order
    if flashError
      .flash.flash-warn
        i.bi.bi-exclamation-triangle-fill(style="flex-shrink:0")
        span= flashError

    .pg-header
      div
        .flex-gap
          span.entity-pill(class=order.order_type === 'PURCHASE' ? 'entity-purchase' : 'entity-sale')
            = order.order_type === 'PURCHASE' ? 'Compra' : 'Venta'
          h1.pg-title Orden ##{order.id.slice(-6).toUpperCase()}
      .pg-actions
        a.btn.btn-secondary(href=order.order_type === 'SALE' ? '/api/orders?type=SALE' : '/api/orders?type=PURCHASE') Volver

    .grid-2-3
      div
        .crd(style="margin-bottom:1.25rem")
          .crd-head
            p.crd-title Información general
          .crd-body
            .grid-2
              div
                .info-row
                  span.info-lbl Estado:
                  span.status-pill(class=`status-${statusBadge}` style="margin-left:0.5rem") #{statusLabel}
                .info-row
                  span.info-lbl Socio:
                  span.info-val= partnerName
                .info-row
                  span.info-lbl CUIT:
                  span.info-val= order.partner_cuit
              div
                .info-row
                  span.info-lbl Total:
                  span.info-val(style="font-weight:700;color:#0f172a")= formatCurrency(order.total_amount)
                .info-row
                  span.info-lbl Creada:
                  span.info-val= new Date(order.created_at).toLocaleDateString('es-AR')
                if order.scheduled_date
                  .info-row
                    span.info-lbl Programada:
                    span.info-val= new Date(order.scheduled_date).toLocaleDateString('es-AR')
            if order.notes
              .info-row(style="margin-top:0.5rem")
                span.info-lbl Notas:
                span.info-val= order.notes

        .crd
          .crd-head
            p.crd-title Ítems de la orden
          .crd-body(style="padding:0")
            table.tbl
              thead
                tr
                  th Producto
                  th(style="text-align:center") Cantidad
                  th(style="text-align:right") Precio unit.
                  th(style="text-align:right") Subtotal
              tbody
                each item in order.items
                  tr
                    td= item.product_name
                    td(style="text-align:center")= item.quantity
                    td(style="text-align:right")= formatCurrency(item.unit_price)
                    td(style="text-align:right")= formatCurrency(item.quantity * item.unit_price)
              tfoot
                tr
                  td(colspan="3" style="text-align:right;padding:0.75rem 1rem;background:#0f172a;color:#fff;font-weight:700") Total
                  td(style="text-align:right;padding:0.75rem 1rem;background:#0f172a;color:#fff;font-weight:700")= formatCurrency(order.total_amount)

      .crd
        .crd-head
          p.crd-title Acciones
        .crd-body(style="display:flex;flex-direction:column;gap:0.75rem")
          if order.order_type === 'PURCHASE'
            if order.status === 'TO_VERIFY_BUDGET' || order.status === 'PENDING_BUDGET'
              .flash.flash-info(style="margin:0")
                i.bi.bi-info-circle(style="flex-shrink:0")
                span La confirmación del presupuesto se gestiona desde
                  a(href="/api/transactions")  Finanzas
                  | .
            else if order.status === 'TO_CONFIRM'
              form(action=`/api/orders/purchase/${order.id}/confirm`, method="POST")
                button.btn.btn-primary.w-100(type="submit") Confirmar orden
            else if order.status === 'CONFIRMED' || order.status === 'RECEIVED'
              .flash.flash-info(style="margin:0")
                i.bi.bi-box-seam(style="flex-shrink:0")
                span La recepción se gestiona desde
                  a(href="/api/inventory?tab=purchase")  Inventario
                  | .
            else
              p(style="color:#94a3b8;font-size:0.875rem;text-align:center;margin:0") Sin acciones disponibles

          else if order.order_type === 'SALE'
            if order.status === 'TO_VERIFY_COLLECTION' || order.status === 'PENDING_PAYMENT'
              .flash.flash-info(style="margin:0")
                i.bi.bi-info-circle(style="flex-shrink:0")
                span La confirmación del cobro se gestiona desde
                  a(href="/api/transactions")  Finanzas
                  | .
            else if order.status === 'PENDING_ASSEMBLY' || order.status === 'DISPATCHING'
              .flash.flash-info(style="margin:0")
                i.bi.bi-box-seam(style="flex-shrink:0")
                span El armado y despacho se gestiona desde
                  a(href="/api/inventory?tab=sale")  Inventario
                  | .
            else
              p(style="color:#94a3b8;font-size:0.875rem;text-align:center;margin:0") Sin acciones disponibles
          .card.shadow-sm
            .card-header.bg-light
              strong Acciones
            .card-body.d-grid.gap-2

              if order.order_type === 'PURCHASE'
                if order.status === 'TO_VERIFY_BUDGET' || order.status === 'PENDING_BUDGET'
                  .alert.alert-info.mb-0.small
                    i.bi.bi-info-circle.me-1
                    if canAccessFinanceView
                      | La confirmación del presupuesto y la cancelación se gestionan desde&nbsp;
                      a(href="/api/transactions") Finanzas
                      | .
                    else
                      | La confirmación del presupuesto y la cancelación se gestionan por el área de Finanzas.
                else if order.status === 'TO_CONFIRM'
                  form(action=`/api/orders/purchase/${order.id}/confirm`, method="POST")
                    button.btn.btn-primary.w-100(type="submit") Confirmar orden (mail proveedor)
                else if order.status === 'CONFIRMED' || order.status === 'RECEIVED'
                  .alert.alert-info.mb-0.small
                    i.bi.bi-box-seam.me-1
                    | La recepción y auditoría se gestionan desde&nbsp;
                    a(href="/api/inventory?tab=purchase") Inventario
                    | .
                else
                  p.text-muted.mb-0.text-center Sin acciones disponibles

              else if order.order_type === 'SALE'
                if order.status === 'TO_VERIFY_COLLECTION' || order.status === 'PENDING_PAYMENT'
                  .alert.alert-info.mb-0.small
                    i.bi.bi-info-circle.me-1
                    if canAccessFinanceView
                      | La confirmación del cobro y la cancelación se gestionan desde&nbsp;
                      a(href="/api/transactions") Finanzas
                      | .
                    else
                      | La confirmación del cobro y la cancelación se gestionan por el área de Finanzas.
                else if order.status === 'PENDING_ASSEMBLY' || order.status === 'DISPATCHING'
                  .alert.alert-info.mb-0.small
                    i.bi.bi-box-seam.me-1
                    | El armado y despacho se gestionan desde&nbsp;
                    a(href="/api/inventory?tab=sale") Inventario
                    | .
                else
                  p.text-muted.mb-0.text-center Sin acciones disponibles

      .card.shadow-sm
        .card-header.bg-light
          strong Ítems de la orden
        .card-body
          table.table.table-bordered.mb-0
            thead.table-light
              tr
                th Producto
                th.text-center Cantidad
                th.text-end Precio unitario
                th.text-end Subtotal
            tbody
              each item in (order.items || [])
                tr
                  td= item.product_name
                  td.text-center= item.quantity
                  td.text-end= formatCurrency(item.unit_price)
                  td.text-end= formatCurrency(item.quantity * item.unit_price)
            tfoot
              tr.table-dark
                td(colspan="3")
                  strong Total
                td.text-end
                  strong= formatCurrency(order.total_amount)
