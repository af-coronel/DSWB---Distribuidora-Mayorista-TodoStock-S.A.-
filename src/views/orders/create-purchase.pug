extends ../layout

block content
  - const form = formData || {}
  - const savedItems = (form.items && Array.isArray(form.items)) ? form.items : null

  .pg-header
    h1.pg-title Nueva Orden de Compra
    .pg-actions
      a.btn.btn-secondary(href="/api/orders?type=PURCHASE") Cancelar

  if errorMessage
    .flash.flash-err
      i.bi.bi-exclamation-triangle-fill(style="flex-shrink:0")
      span= errorMessage

  if !products || products.length === 0
    .flash.flash-warn
      i.bi.bi-exclamation-triangle-fill(style="flex-shrink:0")
      span No hay productos disponibles. Verificá que los proveedores estén activos.

  else
    .flash.flash-info
      i.bi.bi-info-circle(style="flex-shrink:0")
      div
        strong El sistema genera una orden por proveedor.
        |  Si los ítems pertenecen a proveedores distintos, se crearán múltiples órdenes de compra y sus respectivas órdenes de pago.

    .crd
      .crd-head
        .flex-between
          p.crd-title Ítems de la orden
          button.btn.btn-sm.btn-primary(type="button", onclick="addItem()")
            i.bi.bi-plus-circle
            | Agregar ítem
      form#purchase-form(action="/api/orders/purchase", method="POST", onsubmit="return validateForm(event)")
        .crd-body(style="padding:0")
          table.tbl
            thead
              tr
                th(style="width:38%") Producto (Proveedor)
                th(style="text-align:center;width:14%") Cantidad
                th(style="text-align:center;width:12%") Stock actual
                th(style="text-align:right;width:14%") Precio unit.
                th(style="text-align:right;width:14%") Subtotal
                th(style="width:8%")
            tbody#items-container

              if savedItems
                each item, index in savedItems
                  tr.item-row(data-index=index)
                    td
                      select.form-select.form-select-sm.product-select(name=`items[${index}][product_id]`, required, onchange="updateRow(this)")
                        option(value="") Seleccionar producto
                        each product in products
                          option(value=product.id, data-price=product.vendor_price, data-stock=product.available_stock, selected=(item.product_id === product.id))
                            = `${product.name} — ${vendorMap[product.vendor_cuit] || product.vendor_cuit} (stock: ${product.available_stock})`
                    td(style="text-align:center")
                      input.form-control.form-control-sm(type="number", name=`items[${index}][quantity]`, min="1", max="9999", value=item.quantity || 1, required, oninput="updateRow(this.closest('tr').querySelector('.product-select'))")
                    td.text-center.available-stock —
                    td.text-end.unit-price —
                    td.text-end.subtotal —
                    td(style="text-align:center")
                      button.btn.btn-sm.btn-outline-danger(type="button", onclick="removeItem(this)")
                        i.bi.bi-trash

              else
                tr.item-row(data-index="0")
                  td
                    select.form-select.form-select-sm.product-select(name="items[0][product_id]", required, onchange="updateRow(this)")
                      option(value="") Seleccionar producto
                      each product in products
                        option(value=product.id, data-price=product.vendor_price, data-stock=product.available_stock)
                          = `${product.name} — ${vendorMap[product.vendor_cuit] || product.vendor_cuit} (stock: ${product.available_stock})`
                  td(style="text-align:center")
                    input.form-control.form-control-sm(type="number", name="items[0][quantity]", min="1", max="9999", value="1", required, oninput="updateRow(this.closest('tr').querySelector('.product-select'))")
                  td.text-center.available-stock —
                  td.text-end.unit-price —
                  td.text-end.subtotal —
                  td(style="text-align:center")
                    button.btn.btn-sm.btn-outline-danger(type="button", onclick="removeItem(this)")
                      i.bi.bi-trash

        .crd-foot
          .flex-gap
            strong Total estimado:
            span#grand-total.fw-bold —

      hr.frm-divider

      .crd-body
        .frm-group
          label.frm-label Notas (opcional)
          textarea.frm-ctrl(name="notes", rows="2", form="purchase-form")= form.notes || ""
      .crd-foot
        a.btn.btn-secondary(href="/api/orders?type=PURCHASE") Cancelar
        button.btn.btn-primary(type="submit", form="purchase-form")
          i.bi.bi-check2-circle
          | Crear Orden de Compra

block scripts
  script.
    let itemIndex = #{savedItems ? savedItems.length : 1};
    const allProducts = !{JSON.stringify((products || []).map(p => ({ id: p.id, name: p.name, price: p.vendor_price, vendor: vendorMap[p.vendor_cuit] || p.vendor_cuit, stock: p.available_stock })))};

    function buildOptions(selectedId) {
      return allProducts.map(p =>
        `<option value="${p.id}" data-price="${p.price}" data-stock="${p.stock}"${p.id === selectedId ? ' selected' : ''}>${p.name} — ${p.vendor} (stock: ${p.stock})</option>`
      ).join('');
    }

    function addItem() {
      const tbody = document.getElementById('items-container');
      const tr = document.createElement('tr');
      tr.className = 'item-row';
      tr.dataset.index = itemIndex;
      tr.innerHTML = `
        <td>
          <select class="form-select form-select-sm product-select" name="items[${itemIndex}][product_id]" required onchange="updateRow(this)">
            <option value="">Seleccionar producto</option>
            ${buildOptions(null)}
          </select>
        </td>
        <td class="text-center">
          <input class="form-control form-control-sm" type="number" name="items[${itemIndex}][quantity]"
            min="1" max="9999" value="1" required oninput="updateRow(this.closest('tr').querySelector('.product-select'))">
        </td>
        <td class="text-center available-stock">—</td>
        <td class="text-end unit-price">—</td>
        <td class="text-end subtotal">—</td>
        <td class="text-center">
          <button class="btn btn-sm btn-outline-danger" type="button" onclick="removeItem(this)">
            <i class="bi bi-trash"></i>
          </button>
        </td>
      `;
      tbody.appendChild(tr);
      itemIndex++;
    }

    function removeItem(btn) {
      const rows = document.querySelectorAll('.item-row');
      if (rows.length > 1) {
        btn.closest('tr').remove();
        reindexItems();
        recalcTotal();
      } else {
        btn.disabled = true;
        btn.innerHTML = '<i class="bi bi-dash-circle"></i>';
        setTimeout(() => { btn.disabled = false; btn.innerHTML = '<i class="bi bi-trash"></i>'; }, 1500);
      }
    }

    function reindexItems() {
      document.querySelectorAll('.item-row').forEach((row, i) => {
        row.querySelector('[name$="[product_id]"]').name = `items[${i}][product_id]`;
        row.querySelector('[name$="[quantity]"]').name = `items[${i}][quantity]`;
      });
    }

    function updateRow(select) {
      const row = select.closest('tr');
      const opt = select.options[select.selectedIndex];
      const price = parseFloat(opt?.dataset?.price) || 0;
      const stock = parseInt(opt?.dataset?.stock) || 0;
      const qty = parseInt(row.querySelector('input[type="number"]')?.value) || 0;
      row.querySelector('.available-stock').textContent = opt?.value ? String(stock) : '—';
      row.querySelector('.unit-price').textContent = price > 0 ? window.formatCurrency(price) : '—';
      row.querySelector('.subtotal').textContent = price > 0 && qty > 0 ? window.formatCurrency(price * qty) : '—';
      recalcTotal();
    }

    function recalcTotal() {
      let total = 0;
      document.querySelectorAll('.item-row').forEach(row => {
        const select = row.querySelector('.product-select');
        const opt = select?.options[select.selectedIndex];
        const price = parseFloat(opt?.dataset?.price) || 0;
        const qty = parseInt(row.querySelector('input[type="number"]')?.value) || 0;
        total += price * qty;
      });
      document.getElementById('grand-total').textContent = total > 0 ? window.formatCurrency(total) : '—';
    }

    function validateForm(event) {
      const selects = document.querySelectorAll('.product-select');
      const hasItem = Array.from(selects).some(s => s.value !== '');
      if (!hasItem) {
        event.preventDefault();
        alert('Debe agregar al menos un ítem con producto seleccionado.');
        return false;
      }
    }

    document.addEventListener('DOMContentLoaded', () => {
      document.querySelectorAll('.product-select').forEach(select => updateRow(select));
      recalcTotal();
    });
