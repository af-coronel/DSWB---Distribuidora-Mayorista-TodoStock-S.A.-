extends ../layout

block content
  .container.mt-5
    .d-flex.justify-content-between.align-items-center.mb-3
      h2 Nueva Orden de Compra
      a.btn.btn-outline-secondary(href="/api/orders") Volver al listado

    if errorMessage
      .alert.alert-danger= errorMessage

    if !vendors || vendors.length === 0
      .alert.alert-warning
        | No hay proveedores activos.
        a(href="/api/vendors/new") Crear proveedor

    else if !products || products.length === 0
      .alert.alert-warning No hay productos registrados para agregar a la orden.

    else
      .row.justify-content-center
        .col-md-10
          .card.shadow
            .card-header.bg-dark.text-white
              h4.mb-0 Datos de la orden
            .card-body
              form(action="/api/orders/purchase", method="POST")

                .row.mb-3
                  .col-md-6
                    label.form-label Proveedor
                    select.form-select(name="partner_cuit", required)
                      option(value="") Seleccionar proveedor
                      each vendor in vendors
                        option(value=vendor.cuit)= `${vendor.legal_name} — ${vendor.cuit}`
                  .col-md-6
                    label.form-label Fecha estimada de recepción (opcional)
                    input.form-control(type="date", name="scheduled_date")

                .mb-3
                  label.form-label Notas (opcional)
                  textarea.form-control(name="notes", rows="2")

                hr
                .d-flex.justify-content-between.align-items-center.mb-2
                  h5.mb-0 Ítems
                  button.btn.btn-sm.btn-outline-primary(type="button", onclick="addItem()") + Agregar ítem

                #items-container
                  .item-row.row.mb-2.align-items-end(data-index="0")
                    .col-md-7
                      label.form-label Producto
                      select.form-select.product-select(name="items[0][product_id]", required, onchange="updatePrice(this)")
                        option(value="") Seleccionar producto
                        each product in products
                          option(value=product.id, data-price=product.vendor_price)= `${product.name} — $${product.vendor_price}`
                    .col-md-3
                      label.form-label Cantidad
                      input.form-control(type="number", name="items[0][quantity]", min="1", value="1", required)
                    .col-md-2.d-flex.align-items-end
                      button.btn.btn-outline-danger.w-100(type="button", onclick="removeItem(this)") Quitar

                .d-flex.justify-content-between.mt-4
                  a.btn.btn-secondary(href="/api/orders") Cancelar
                  button.btn.btn-dark(type="submit") Crear Orden de Compra

  script.
    let itemIndex = 1;
    const productOptions = document.querySelector('.product-select').innerHTML;

    function addItem() {
      const container = document.getElementById('items-container');
      const row = document.createElement('div');
      row.className = 'item-row row mb-2 align-items-end';
      row.dataset.index = itemIndex;
      row.innerHTML = `
        <div class="col-md-7">
          <label class="form-label">Producto</label>
          <select class="form-select product-select" name="items[${itemIndex}][product_id]" required onchange="updatePrice(this)">
            ${productOptions}
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label">Cantidad</label>
          <input class="form-control" type="number" name="items[${itemIndex}][quantity]" min="1" value="1" required>
        </div>
        <div class="col-md-2 d-flex align-items-end">
          <button class="btn btn-outline-danger w-100" type="button" onclick="removeItem(this)">Quitar</button>
        </div>
      `;
      container.appendChild(row);
      itemIndex++;
    }

    function removeItem(btn) {
      const row = btn.closest('.item-row');
      const rows = document.querySelectorAll('.item-row');
      if (rows.length > 1) {
        row.remove();
        reindexItems();
      }
    }

    function reindexItems() {
      document.querySelectorAll('.item-row').forEach((row, i) => {
        row.querySelector('[name$="[product_id]"]').name = `items[${i}][product_id]`;
        row.querySelector('[name$="[quantity]"]').name = `items[${i}][quantity]`;
      });
    }

    function updatePrice(select) {
      const option = select.options[select.selectedIndex];
    }
