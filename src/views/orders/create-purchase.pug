extends ../layout

block content
  - const form = formData || {}
  - const savedItems = (form.items && Array.isArray(form.items)) ? form.items : null
  .container.mt-5
    .d-flex.justify-content-between.align-items-center.mb-3
      h2 Nueva Orden de Compra
      a.btn.btn-outline-secondary(href="/api/orders") Volver al listado

    if errorMessage
      .alert.alert-danger.alert-dismissible.fade.show
        i.bi.bi-exclamation-triangle-fill.me-2
        = errorMessage
        button.btn-close(type="button", data-bs-dismiss="alert", aria-label="Cerrar")

    if !vendors || vendors.length === 0
      .alert.alert-warning.d-flex.align-items-center.gap-2
        i.bi.bi-exclamation-triangle-fill
        span No hay proveedores activos.
        a.btn.btn-sm.btn-primary.ms-auto(href="/api/vendors/new") Crear proveedor

    else if !products || products.length === 0
      .alert.alert-warning No hay productos registrados para agregar a la orden.

    else
      .row.justify-content-center
        .col-md-10
          .card.shadow
            .card-header.bg-dark.text-white
              h4.mb-0 Datos de la orden
            .card-body
              form(action="/api/orders/purchase", method="POST", onsubmit="return validateForm(event)")

                .row.mb-3
                  .col-md-6
                    label.form-label Proveedor
                    select.form-select(name="partner_cuit", required)
                      option(value="") Seleccionar proveedor
                      each vendor in vendors
                        option(value=vendor.cuit, selected=(form.partner_cuit === vendor.cuit))= `${vendor.legal_name} — ${vendor.cuit}`
                  .col-md-6
                    label.form-label Fecha estimada de recepción (opcional)
                    input.form-control(type="date", name="scheduled_date", value=form.scheduled_date || "")

                .mb-3
                  label.form-label Notas (opcional)
                  textarea.form-control(name="notes", rows="2")= form.notes || ""

                hr
                .d-flex.justify-content-between.align-items-center.mb-2
                  h5.mb-0 Ítems
                  button.btn.btn-sm.btn-outline-primary(type="button", onclick="addItem()")
                    i.bi.bi-plus-circle.me-1
                    | Agregar ítem

                .table-responsive
                  table.table.table-bordered.mb-2
                    thead.table-dark
                      tr
                        th.col-5 Producto
                        th.col-2.text-center Cantidad
                        th.col-2.text-end Precio unit.
                        th.col-2.text-end Subtotal
                        th.col-1
                    tbody#items-container

                      if savedItems
                        each item, index in savedItems
                          tr.item-row(data-index=index)
                            td
                              select.form-select.form-select-sm.product-select(name=`items[${index}][product_id]`, required, onchange="updateRow(this)")
                                option(value="") Seleccionar producto
                                each product in products
                                  option(value=product.id, data-price=product.vendor_price, selected=(item.product_id === product.id))= product.name
                            td.text-center
                              input.form-control.form-control-sm(type="number", name=`items[${index}][quantity]`, min="1", max="9999", value=item.quantity || 1, required, oninput="updateRow(this.closest('tr').querySelector('.product-select'))")
                            td.text-end.unit-price —
                            td.text-end.subtotal —
                            td.text-center
                              button.btn.btn-sm.btn-outline-danger(type="button", onclick="removeItem(this)")
                                i.bi.bi-trash

                      else
                        tr.item-row(data-index="0")
                          td
                            select.form-select.form-select-sm.product-select(name="items[0][product_id]", required, onchange="updateRow(this)")
                              option(value="") Seleccionar producto
                              each product in products
                                option(value=product.id, data-price=product.vendor_price)= product.name
                          td.text-center
                            input.form-control.form-control-sm(type="number", name="items[0][quantity]", min="1", max="9999", value="1", required, oninput="updateRow(this.closest('tr').querySelector('.product-select'))")
                          td.text-end.unit-price —
                          td.text-end.subtotal —
                          td.text-center
                            button.btn.btn-sm.btn-outline-danger(type="button", onclick="removeItem(this)")
                              i.bi.bi-trash

                  .d-flex.justify-content-end
                    strong.me-2 Total estimado:
                    span#grand-total.fw-bold —

                .d-flex.justify-content-between.mt-4
                  a.btn.btn-secondary(href="/api/orders") Cancelar
                  button.btn.btn-dark(type="submit")
                    i.bi.bi-check2-circle.me-1
                    | Crear Orden de Compra

block scripts
  script.
    let itemIndex = #{savedItems ? savedItems.length : 1};
    const allProducts = !{JSON.stringify((products || []).map(p => ({ id: p.id, name: p.name, price: p.vendor_price })))};

    function buildOptions(selectedId) {
      return allProducts.map(p =>
        `<option value="${p.id}" data-price="${p.price}"${p.id === selectedId ? ' selected' : ''}>${p.name}</option>`
      ).join('');
    }

    function addItem() {
      const tbody = document.getElementById('items-container');
      const tr = document.createElement('tr');
      tr.className = 'item-row';
      tr.dataset.index = itemIndex;
      tr.innerHTML = `
        <td>
          <select class="form-select form-select-sm product-select" name="items[${itemIndex}][product_id]" required onchange="updateRow(this)">
            <option value="">Seleccionar producto</option>
            ${buildOptions(null)}
          </select>
        </td>
        <td class="text-center">
          <input class="form-control form-control-sm" type="number" name="items[${itemIndex}][quantity]"
            min="1" max="9999" value="1" required oninput="updateRow(this.closest('tr').querySelector('.product-select'))">
        </td>
        <td class="text-end unit-price">—</td>
        <td class="text-end subtotal">—</td>
        <td class="text-center">
          <button class="btn btn-sm btn-outline-danger" type="button" onclick="removeItem(this)">
            <i class="bi bi-trash"></i>
          </button>
        </td>
      `;
      tbody.appendChild(tr);
      itemIndex++;
    }

    function removeItem(btn) {
      const rows = document.querySelectorAll('.item-row');
      if (rows.length > 1) {
        btn.closest('tr').remove();
        reindexItems();
        recalcTotal();
      } else {
        btn.disabled = true;
        btn.innerHTML = '<i class="bi bi-dash-circle"></i>';
        setTimeout(() => { btn.disabled = false; btn.innerHTML = '<i class="bi bi-trash"></i>'; }, 1500);
      }
    }

    function reindexItems() {
      document.querySelectorAll('.item-row').forEach((row, i) => {
        row.querySelector('[name$="[product_id]"]').name = `items[${i}][product_id]`;
        row.querySelector('[name$="[quantity]"]').name = `items[${i}][quantity]`;
      });
    }

    function updateRow(select) {
      const row = select.closest('tr');
      const opt = select.options[select.selectedIndex];
      const price = parseFloat(opt?.dataset?.price) || 0;
      const qty = parseInt(row.querySelector('input[type="number"]')?.value) || 0;
      row.querySelector('.unit-price').textContent = price > 0 ? `$ ${price.toFixed(2)}` : '—';
      row.querySelector('.subtotal').textContent = price > 0 && qty > 0 ? `$ ${(price * qty).toFixed(2)}` : '—';
      recalcTotal();
    }

    function recalcTotal() {
      let total = 0;
      document.querySelectorAll('.item-row').forEach(row => {
        const select = row.querySelector('.product-select');
        const opt = select?.options[select.selectedIndex];
        const price = parseFloat(opt?.dataset?.price) || 0;
        const qty = parseInt(row.querySelector('input[type="number"]')?.value) || 0;
        total += price * qty;
      });
      document.getElementById('grand-total').textContent = total > 0 ? `$ ${total.toFixed(2)}` : '—';
    }

    function validateForm(event) {
      const selects = document.querySelectorAll('.product-select');
      const hasItem = Array.from(selects).some(s => s.value !== '');
      if (!hasItem) {
        event.preventDefault();
        alert('Debe agregar al menos un ítem con producto seleccionado.');
        return false;
      }
    }

    document.addEventListener('DOMContentLoaded', recalcTotal);
