extends ../layout
block content
  - const customerData = partner.customer_data || {}
  - const vendorData = partner.vendor_data || {}
  .container.mt-5
    if errorMessage
      .alert.alert-danger= errorMessage

    .row.justify-content-center
      .col-md-8
        .card.shadow
          .card-header.bg-dark.text-white
            h3.mb-0 Editar #{activeTab === 'clients' ? 'Cliente' : 'Proveedor'}
          .card-body
            form(action=`/api/${activeTab}/${partner.cuit}/edit`, method="POST")
              .row.mb-3
                .col-md-6
                  label.form-label CUIT
                  input.form-control(type="text", value=partner.cuit, disabled)
                .col-md-6
                  label.form-label Razón Social
                  input.form-control(type="text", name="legal_name", value=partner.legal_name, required)

              .row.mb-3
                .col-md-6
                  label.form-label Email
                  input.form-control(type="email", name="email", value=partner.email, required)
                .col-md-6
                  label.form-label Teléfono
                  input.form-control(type="text", name="phone", value=partner.phone, required)

              .mb-3
                label.form-label Dirección Legal
                input.form-control(type="text", name="legal_address", value=partner.legal_address, required)

              .mb-3
                label.form-label Condición de IVA
                select.form-select(name="vat_condition", required)
                  option(value="Responsable Inscripto", selected=partner.vat_condition === 'Responsable Inscripto') Responsable Inscripto
                  option(value="Monotributista", selected=partner.vat_condition === 'Monotributista') Monotributista
                  option(value="Exento", selected=partner.vat_condition === 'Exento') Exento
                  option(value="No especificado", selected=partner.vat_condition === 'No especificado') No especificado

              if activeTab === 'clients'
                hr
                h5 Datos de Crédito
                .row.mb-3
                  .col-md-6
                    label.form-label Límite de Crédito
                    input.form-control(type="number", name="credit_limit", value=customerData.credit_limit || 0, min="0")
              else
                hr
                h5 Datos de Logística
                .row.mb-3
                  .col-md-6
                    label.form-label Categoría
                    select.form-select(name="category")
                      option(value="Alimentos", selected=vendorData.category === 'Alimentos') Alimentos
                      option(value="Limpieza", selected=vendorData.category === 'Limpieza') Limpieza
                      option(value="Bebidas", selected=vendorData.category === 'Bebidas') Bebidas
                      option(value="Bazar", selected=vendorData.category === 'Bazar') Bazar
                      option(value="General", selected=!vendorData.category || vendorData.category === 'General') General
                  .col-md-6
                    label.form-label Lead Time (Días de entrega)
                    input.form-control(type="number", name="lead_time", value=vendorData.lead_time || 0, min="0")

              .d-flex.justify-content-between.mt-4
                a.btn.btn-secondary(href=`/api/${activeTab}/${partner.cuit}`) Cancelar
                button.btn.btn-dark(type="submit") Guardar Cambios