extends ../layout
block content
  .container.mt-5
    if successMessage
      .alert.alert-success= successMessage
    if errorMessage
      .alert.alert-danger= errorMessage

    #partner-action-modal.position-fixed.top-0.start-0.w-100.h-100.d-none(style="background: rgba(33, 37, 41, 0.55); z-index: 1055;")
      .d-flex.justify-content-center.align-items-center.w-100.h-100.p-3
        .card.shadow-lg.border-0(style="width: 100%; max-width: 460px;")
          .card-header.bg-dark.text-white
            h5.mb-0 Confirmar acción
          .card-body
            p.mb-0#partner-action-message
          .card-footer.bg-white.d-flex.justify-content-end.gap-2
            button.btn.btn-outline-secondary(type="button", onclick="closePartnerActionModal()") Cancelar
            button.btn.btn-dark(type="button", onclick="confirmPartnerAction()") Confirmar

    .card.shadow
      .card-header.bg-dark.text-white.d-flex.justify-content-between.align-items-center
        h3.mb-0 Detalle del #{activeTab === 'clients' ? 'Cliente' : 'Proveedor'}: #{partner.legal_name}
        span.badge(class=partner.active ? 'bg-success' : 'bg-danger') #{partner.active ? 'Activo' : 'Inactivo'}
      .card-body
        .row
          .col-md-6
            h5 Información General
            p: strong CUIT: #{partner.cuit}
            p: strong Email: #{partner.email}
            p: strong Teléfono: #{partner.phone || 'No registrado'}
            p: strong Dirección: #{partner.legal_address}
            p: strong Condición IVA: #{partner.vat_condition}
          .col-md-6
            if activeTab === 'clients'
              h5 Información Comercial
              .alert.alert-light.border
                p: strong Límite de Crédito: $#{partner.customer_data.credit_limit || 0}
                p: strong Saldo Actual: $#{partner.customer_data.current_balance || 0}
            else
              h5 Información Logística
              .alert.alert-light.border
                p: strong Categoría: #{partner.vendor_data.category || 'General'}
                p: strong Lead Time: #{partner.vendor_data.lead_time || 0} días

            h5 Auditoría
            p.small.text-muted Creado el: #{new Date(partner.created_at).toLocaleDateString()}
            p.small.text-muted Por: #{partner.created_by}

      .card-footer.d-flex.justify-content-between
        a.btn.btn-secondary(href=`/api/${activeTab}`) Volver al listado
        div
          a.btn.btn-warning.me-2(href=`/api/${activeTab}/${partner.cuit}/edit`) Editar
          if partner.active
            button.btn.btn-danger(type="button", onclick=`openPartnerAction('${partner.cuit}', 'deactivate', '${activeTab}')`) Desactivar
          else
            button.btn.btn-success(type="button", onclick=`openPartnerAction('${partner.cuit}', 'activate', '${activeTab}')`) Activar

  script.
    let pendingPartnerAction = null;

    function openPartnerAction(cuit, action, tab) {
      const label = action === 'activate' ? 'activar' : 'desactivar';
      pendingPartnerAction = { cuit, action, tab };

      const box = document.getElementById('partner-action-modal');
      const message = document.getElementById('partner-action-message');

      if (!box || !message) return;

      message.textContent = `¿Está seguro que desea ${label} este socio de negocio?`;
      box.classList.remove('d-none');
    }

    function closePartnerActionModal() {
      pendingPartnerAction = null;
      const box = document.getElementById('partner-action-modal');
      if (box) {
        box.classList.add('d-none');
      }
    }

    async function confirmPartnerAction() {
      if (!pendingPartnerAction) return;

      const { cuit, action, tab } = pendingPartnerAction;
      try {
        const res = await fetch(`/api/${tab}/${cuit}/${action}`, { method: 'PATCH' });
        const data = await res.json();
        if (res.ok) {
          const query = action === 'activate' ? 'activated=1' : 'deactivated=1';
          window.location.href = `/api/${tab}/${cuit}?${query}`;
        } else {
          const message = data && data.message ? data.message : 'No se pudo actualizar el estado del socio de negocio.';
          window.location.href = `/api/${tab}/${cuit}?error=${encodeURIComponent(message)}`;
        }
      } catch (e) {
        const message = e && e.message ? `Error de conexión: ${e.message}` : 'Error de conexión.';
        window.location.href = `/api/${tab}/${cuit}?error=${encodeURIComponent(message)}`;
      }
    }