extends ../layout
block content

  #partner-action-modal.modal-ov.d-none
    .modal-box
      .modal-head
        h2.modal-ttl Confirmar acción
      .modal-body
        p#partner-action-message(style="margin:0")
      .modal-foot
        button.btn.btn-secondary(type="button", onclick="closePartnerActionModal()") Cancelar
        button.btn.btn-danger(type="button", onclick="confirmPartnerAction()") Confirmar

  if successMessage
    .flash.flash-ok
      i.bi.bi-check-circle-fill(style="flex-shrink:0")
      span= successMessage
  if errorMessage
    .flash.flash-err
      i.bi.bi-exclamation-triangle-fill(style="flex-shrink:0")
      span= errorMessage

  .pg-header
    div
      .flex-gap
        h1.pg-title= partner.legal_name
        span.status-pill(class=partner.active ? 'status-done' : 'status-cancelled')
          = partner.active ? 'Activo' : 'Inactivo'
      p.pg-sub CUIT #{partner.cuit} &mdash; #{activeTab === 'clients' ? 'Cliente' : 'Proveedor'}
    .pg-actions
      a.btn.btn-secondary(href=`/api/${activeTab}`) Volver
      a.btn.btn-warning(href=`/api/${activeTab}/${partner.cuit}/edit`) Editar
      if partner.active
        button.btn.btn-danger(type="button", onclick=`openPartnerAction('${partner.cuit}', 'deactivate', '${activeTab}')`) Desactivar
      else
        button.btn.btn-success(type="button", onclick=`openPartnerAction('${partner.cuit}', 'activate', '${activeTab}')`) Activar

  .grid-2
    .crd
      .crd-head
        p.crd-title Información General
      .crd-body
        .info-row
          span.info-lbl CUIT:
          span.info-val= partner.cuit
        .info-row
          span.info-lbl Email:
          span.info-val= partner.email
        .info-row
          span.info-lbl Teléfono:
          span.info-val= partner.phone || 'No registrado'
        .info-row
          span.info-lbl Dirección:
          span.info-val= partner.legal_address
        .info-row
          span.info-lbl Condición IVA:
          span.info-val= partner.vat_condition

    .crd
      .crd-head
        p.crd-title= activeTab === 'clients' ? 'Información Comercial' : 'Información Logística'
      .crd-body
        if activeTab === 'clients'
          .info-row
            span.info-lbl Límite de Crédito:
            span.info-val= formatCurrency(partner.customer_data.credit_limit || 0)
          .info-row
            span.info-lbl Saldo Actual:
            span.info-val= formatCurrency(partner.customer_data.current_balance || 0)
        else
          .info-row
            span.info-lbl Categoría:
            span.info-val= partner.vendor_data.category || 'General'
          .info-row
            span.info-lbl Lead Time:
            span.info-val #{partner.vendor_data.lead_time || 0} días
        hr.frm-divider
        p.frm-hint Creado el: #{new Date(partner.created_at).toLocaleDateString()}
        p.frm-hint Por: #{partner.created_by}

  script.
    let pendingPartnerAction = null;

    function openPartnerAction(cuit, action, tab) {
      const label = action === 'activate' ? 'activar' : 'desactivar';
      pendingPartnerAction = { cuit, action, tab };

      const box = document.getElementById('partner-action-modal');
      const message = document.getElementById('partner-action-message');

      if (!box || !message) return;

      message.textContent = `¿Está seguro que desea ${label} este socio de negocio?`;
      box.classList.remove('d-none');
    }

    function closePartnerActionModal() {
      pendingPartnerAction = null;
      const box = document.getElementById('partner-action-modal');
      if (box) {
        box.classList.add('d-none');
      }
    }

    async function confirmPartnerAction() {
      if (!pendingPartnerAction) return;

      const { cuit, action, tab } = pendingPartnerAction;
      try {
        const res = await fetch(`/api/${tab}/${cuit}/${action}`, { method: 'PATCH' });
        const data = await res.json();
        if (res.ok) {
          const query = action === 'activate' ? 'activated=1' : 'deactivated=1';
          window.location.href = `/api/${tab}/${cuit}?${query}`;
        } else {
          const message = data && data.message ? data.message : 'No se pudo actualizar el estado del socio de negocio.';
          window.location.href = `/api/${tab}/${cuit}?error=${encodeURIComponent(message)}`;
        }
      } catch (e) {
        const message = e && e.message ? `Error de conexión: ${e.message}` : 'Error de conexión.';
        window.location.href = `/api/${tab}/${cuit}?error=${encodeURIComponent(message)}`;
      }
    }