doctype html
html(lang="es")
  head
    title TodoStock S.A. - Clientes
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
body
  .container.mt-5
    h1 Gestión de Socios de Negocio
    hr

    // --- SISTEMA DE TABS ---
    ul.nav.nav-tabs.mb-4
      li.nav-item
        a.nav-link(class=activeTab === 'clients' ? 'active font-weight-bold' : '', href="/api/clients") 
          i.bi.bi-people-fill.me-2
          | Clientes
      li.nav-item
        a.nav-link(class=activeTab === 'vendors' ? 'active font-weight-bold' : '', href="/api/vendors") 
          i.bi.bi-truck.me-2
          | Proveedores

    // --- CONTENIDO DINÁMICO ---
    .d-flex.justify-content-between.align-items-center.mb-3
      h2= activeTab === 'clients' ? 'Cartera de Clientes' : 'Lista de Proveedores'
      
      // El botón de "Nuevo" ahora apunta dinámicamente según la tab
      a.btn.btn-primary(href=`/api/${activeTab}/new`) 
        | + Nuevo #{activeTab === 'clients' ? 'Cliente' : 'Proveedor'}

    if partners && partners.length > 0
      table.table.table-striped.table-hover
        thead.table-dark
          tr
            th CUIT
            th Razón Social
            th Estado
            th Acciones
        tbody
          each partner in partners
            tr
              td= partner.cuit
              td= partner.legal_name
              td
                span.badge(class=partner.active ? 'bg-success' : 'bg-danger') 
                  | #{partner.active ? 'Activo' : 'Inactivo'}
              td 
                // Ajustamos la ruta del "Ver" para que use la tab activa
                a.btn.btn-sm.btn-outline-primary.me-2(href=`/api/${activeTab}/${partner.cuit}`) Ver
                button.btn.btn-sm.btn-outline-danger Desactivar
    else
      .alert.alert-info
        | No se encontraron #{activeTab === 'clients' ? 'clientes' : 'proveedores'} registrados.