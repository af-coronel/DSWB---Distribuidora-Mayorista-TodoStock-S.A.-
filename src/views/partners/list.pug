extends ../layout
block content
  
  .container.mt-5
    if successMessage
      .alert.alert-success= successMessage
    if errorMessage
      .alert.alert-danger= errorMessage

    #partner-list-action-modal.position-fixed.top-0.start-0.w-100.h-100.d-none(style="background: rgba(33, 37, 41, 0.55); z-index: 1055;")
      .d-flex.justify-content-center.align-items-center.w-100.h-100.p-3
        .card.shadow-lg.border-0(style="width: 100%; max-width: 460px;")
          .card-header.bg-dark.text-white
            h5.mb-0 Confirmar acción
          .card-body
            p.mb-0#partner-list-action-message
          .card-footer.bg-white.d-flex.justify-content-end.gap-2
            button.btn.btn-outline-secondary(type="button", onclick="closeListPartnerActionModal()") Cancelar
            button.btn.btn-dark(type="button", onclick="confirmListPartnerAction()") Confirmar

    // --- CONTENIDO DINÁMICO ---
    .d-flex.justify-content-between.align-items-center.mb-3
      h2= activeTab === 'clients' ? 'Cartera de Clientes' : 'Lista de Proveedores'
      
      // El botón de "Nuevo" ahora apunta dinámicamente según la tab
      a.btn.btn-primary(href=`/api/${activeTab}/new`) 
        | + Nuevo #{activeTab === 'clients' ? 'Cliente' : 'Proveedor'}

    if partners && partners.length > 0
      table.table.table-striped.table-hover
        thead.table-dark
          tr
            th CUIT
            th Razón Social
            th Estado
            th Acciones
        tbody
          each partner in partners
            tr
              td= partner.cuit
              td= partner.legal_name
              td
                span.badge(class=partner.active ? 'bg-success' : 'bg-danger') 
                  | #{partner.active ? 'Activo' : 'Inactivo'}
              td 
                // Ajustamos la ruta del "Ver" para que use la tab activa
                a.btn.btn-sm.btn-outline-primary.me-2(href=`/api/${activeTab}/${partner.cuit}`) Ver
                if partner.active
                  button.btn.btn-sm.btn-outline-danger(
                    type="button",
                    onclick=`openListPartnerAction('${partner.cuit}', 'deactivate', '${activeTab}')`
                  ) Desactivar
                else
                  button.btn.btn-sm.btn-outline-success(
                    type="button",
                    onclick=`openListPartnerAction('${partner.cuit}', 'activate', '${activeTab}')`
                  ) Activar
    else
      .alert.alert-info
        | No se encontraron #{activeTab === 'clients' ? 'clientes' : 'proveedores'} registrados.

  script.
    let pendingListPartnerAction = null;

    function openListPartnerAction(cuit, action, tab) {
      const label = action === 'activate' ? 'activar' : 'desactivar';
      pendingListPartnerAction = { cuit, action, tab };

      const box = document.getElementById('partner-list-action-modal');
      const message = document.getElementById('partner-list-action-message');

      if (!box || !message) return;

      message.textContent = `¿Está seguro que desea ${label} este socio de negocio?`;
      box.classList.remove('d-none');
    }

    function closeListPartnerActionModal() {
      pendingListPartnerAction = null;
      const box = document.getElementById('partner-list-action-modal');
      if (box) {
        box.classList.add('d-none');
      }
    }

    async function confirmListPartnerAction() {
      if (!pendingListPartnerAction) return;

      const { cuit, action, tab } = pendingListPartnerAction;
      try {
        const res = await fetch(`/api/${tab}/${cuit}/${action}`, { method: 'PATCH' });
        const data = await res.json();
        if (res.ok) {
          const query = action === 'activate' ? 'activated=1' : 'deactivated=1';
          window.location.href = `/api/${tab}?${query}`;
        } else {
          const message = data && data.message ? data.message : 'No se pudo actualizar el estado del socio de negocio.';
          window.location.href = `/api/${tab}?error=${encodeURIComponent(message)}`;
        }
      } catch (e) {
        const message = e && e.message ? `Error de conexión: ${e.message}` : 'Error de conexión.';
        window.location.href = `/api/${tab}?error=${encodeURIComponent(message)}`;
      }
    }