doctype html
html(lang="es")
  head
    title TodoStock S.A. - Nuevo Cliente
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
  body
    .container.mt-5
      .row.justify-content-center
        .col-md-8
          .card.shadow
            .card-header.bg-primary.text-white
              h3.mb-0 Registrar Nuevo Cliente
            .card-body
              form(action="/api/clients", method="POST")
                .row.mb-3
                  .col-md-6
                    label.form-label CUIT (11 dígitos)
                    input.form-control(type="text", name="cuit", placeholder="20334445556", required)
                  .col-md-6
                    label.form-label Razón Social
                    input.form-control(type="text", name="legal_name", required)
                
                .row.mb-3
                  .col-md-6
                    label.form-label Teléfono
                    input.form-control(type="text", name="phone")
                  .col-md-6
                    label.form-label Email
                    input.form-control(type="email", name="email", required)
                
                .mb-3
                  label.form-label Dirección Legal
                  input.form-control(type="text", name="legal_address")
                
                .mb-3
                  label.form-label Condición de IVA
                  select.form-select(name="vat_condition")
                    option(value="Responsable Inscripto") Responsable Inscripto
                    option(value="Monotributista") Monotributista
                    option(value="Exento") Exento

                hr
                h5 Datos de Crédito
                .row.mb-4
                  .col-md-6
                    label.form-label Límite de Crédito
                    input.form-control(type="number", name="credit_limit", value="0")
                
                .d-flex.justify-content-between
                  a.btn.btn-secondary(href="/api/clients") Cancelar
                  button.btn.btn-success(type="submit") Guardar Cliente