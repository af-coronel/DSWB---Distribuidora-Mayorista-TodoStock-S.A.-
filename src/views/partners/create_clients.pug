extends ../layout
block content
    - const clientForm = formData || {}

    .pg-header
      h1.pg-title Registrar Nuevo Cliente
      .pg-actions
        a.btn.btn-secondary(href="/api/clients") Cancelar

    if errorMessage
      .flash.flash-err
        i.bi.bi-exclamation-triangle-fill(style="flex-shrink:0")
        span= errorMessage

    .crd(style="max-width:680px;margin:0 auto")
      .crd-head
        p.crd-title Datos del cliente
      form#create-form(action="/api/clients", method="POST")
        .crd-body
          .grid-2
            .frm-group
              label.frm-label CUIT (11 dígitos)
              input.frm-ctrl(type="text", name="cuit", placeholder="20334445556", value=clientForm.cuit || "", required, pattern="[0-9]{11}", maxlength="11", minlength="11")
            .frm-group
              label.frm-label Razón Social
              input.frm-ctrl(type="text", name="legal_name", value=clientForm.legal_name || "", required, minlength="2", maxlength="150", placeholder="Distribuidora Sur S.A.")

          .grid-2
            .frm-group
              label.frm-label Email
              input.frm-ctrl(type="email", name="email", value=clientForm.email || "", required)
            .frm-group
              label.frm-label Teléfono
              input.frm-ctrl(type="tel", name="phone", value=clientForm.phone || "", placeholder="1123456789", maxlength="20")

          .frm-group
            label.frm-label Dirección Legal
            input.frm-ctrl(type="text", name="legal_address", value=clientForm.legal_address || "")

          .frm-group
            label.frm-label Condición de IVA
            select.frm-ctrl(name="vat_condition")
              option(value="Responsable Inscripto", selected=clientForm.vat_condition === 'Responsable Inscripto') Responsable Inscripto
              option(value="Monotributista", selected=clientForm.vat_condition === 'Monotributista') Monotributista
              option(value="Exento", selected=clientForm.vat_condition === 'Exento') Exento

          hr.frm-divider
          p.crd-title(style="margin-bottom:1rem") Datos de Crédito
          .grid-2
            .frm-group
              label.frm-label Límite de Crédito
              input.frm-ctrl(type="number", name="credit_limit", value=typeof clientForm.credit_limit !== 'undefined' ? clientForm.credit_limit : "0", min="0", step="0.01", placeholder="0.00")

        .crd-foot
          span
          button.btn.btn-primary(type="submit", form="create-form") Guardar Cliente