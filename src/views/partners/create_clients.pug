extends ../layout
block content
    - const clientForm = formData || {}
    .container.mt-5
      if errorMessage
        .alert.alert-danger.alert-dismissible.fade.show
          i.bi.bi-exclamation-triangle-fill.me-2
          = errorMessage
          button.btn-close(type="button", data-bs-dismiss="alert", aria-label="Cerrar")

      .row.justify-content-center
        .col-md-8
          .card.shadow
            .card-header.bg-primary.text-white
              h3.mb-0 Registrar Nuevo Cliente
            .card-body
              form(action="/api/clients", method="POST")
                .row.mb-3
                  .col-md-6
                    label.form-label CUIT (11 dígitos)
                    input.form-control(type="text", name="cuit", placeholder="20334445556", value=clientForm.cuit || "", required, pattern="[0-9]{11}", maxlength="11", minlength="11", title="Ingresá los 11 dígitos del CUIT sin guiones")
                  .col-md-6
                    label.form-label Razón Social
                    input.form-control(type="text", name="legal_name", value=clientForm.legal_name || "", required, minlength="2", maxlength="150", placeholder="Ej: Distribuidora Sur S.A.")
                
                .row.mb-3
                  .col-md-6
                    label.form-label Teléfono
                    input.form-control(type="tel", name="phone", value=clientForm.phone || "", placeholder="Ej: 1123456789", maxlength="20")
                  .col-md-6
                    label.form-label Email
                    input.form-control(type="email", name="email", value=clientForm.email || "", required)
                
                .mb-3
                  label.form-label Dirección Legal
                  input.form-control(type="text", name="legal_address", value=clientForm.legal_address || "")
                
                .mb-3
                  label.form-label Condición de IVA
                  select.form-select(name="vat_condition")
                    option(value="Responsable Inscripto", selected=clientForm.vat_condition === 'Responsable Inscripto') Responsable Inscripto
                    option(value="Monotributista", selected=clientForm.vat_condition === 'Monotributista') Monotributista
                    option(value="Exento", selected=clientForm.vat_condition === 'Exento') Exento

                hr
                h5 Datos de Crédito
                .row.mb-4
                  .col-md-6
                    label.form-label Límite de Crédito
                    input.form-control(type="number", name="credit_limit", value=typeof clientForm.credit_limit !== 'undefined' ? clientForm.credit_limit : "0", min="0", step="0.01", placeholder="0.00")
                
                .d-flex.justify-content-between
                  a.btn.btn-secondary(href="/api/clients") Cancelar
                  button.btn.btn-success(type="submit") Guardar Cliente