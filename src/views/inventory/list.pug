extends ../layout

block content
  .container.mt-5
    .d-flex.justify-content-between.align-items-center.mb-3
      h2 Inventario

    if lots && lots.length > 0
      table.table.table-striped.table-hover
        thead.table-dark
          tr
            th Producto
            th.text-center Stock total
            th.text-center Reservado
            th.text-center Disponible
            th.text-center Vencimiento
            th Creado
        tbody
          each lot in lots
            - const available = lot.stock - lot.engaged_stock
            - const rowClass = available === 0 ? 'table-danger' : available <= 5 ? 'table-warning' : ''
            tr(class=rowClass)
              td= productMap[lot.product_id] || lot.product_id
              td.text-center= lot.stock
              td.text-center= lot.engaged_stock
              td.text-center
                strong= available
              td.text-center
                if lot.expiration_date
                  = new Date(lot.expiration_date).toLocaleDateString('es-AR')
                else
                  span.text-muted Sin vencimiento
              td= new Date(lot.created_at).toLocaleDateString('es-AR')
    else
      .alert.alert-info Aún no hay lotes de inventario registrados.
