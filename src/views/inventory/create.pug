extends ../layout

block content
  .container.mt-5
    .d-flex.justify-content-between.align-items-center.mb-3
      h2 Nuevo Lote de Inventario
      a.btn.btn-outline-secondary(href="/api/inventory") Volver al inventario

    if errorMessage
      .alert.alert-danger= errorMessage

    if !products || products.length === 0
      .alert.alert-warning
        | No hay productos registrados.
        a(href="/api/products/new") Crear producto

    else
      .row.justify-content-center
        .col-md-6
          .card.shadow
            .card-header.bg-dark.text-white
              h4.mb-0 Datos del lote
            .card-body
              form(action="/api/inventory", method="POST")

                .mb-3
                  label.form-label Producto
                  select.form-select(name="product_id", required)
                    option(value="") Seleccionar producto
                    each product in products
                      option(value=product.id, selected=(formData && formData.product_id === product.id))= `${product.name}`

                .mb-3
                  label.form-label Stock inicial
                  input.form-control(type="number", name="stock", min="1", required, placeholder="Ej: 100", value=(formData ? formData.stock : ''))

                .mb-3
                  label.form-label Fecha de vencimiento (opcional)
                  input.form-control(type="date", name="expiration_date")

                .d-flex.justify-content-between.mt-4
                  a.btn.btn-secondary(href="/api/inventory") Cancelar
                  button.btn.btn-dark(type="submit") Crear Lote
