.flex-between(style="margin-bottom:0.875rem")
  p(style="margin:0;font-size:0.8rem;color:#64748b")
    | Mostrando #{products.length} de #{totalItems || 0} productos
  if viewMode === 'public_sale'
    span.status-pill.status-progress Venta al público
  else if viewMode === 'internal_use'
    span.status-pill.status-neutral Consumo interno
  else
    span.status-pill.status-neutral Todos

if products && products.length > 0
  .tbl-wrap
    table.tbl
      thead
        tr
          th Nombre
          th Proveedor
          th Precio Proveedor
          th Precio Cliente
          th Categoría
          th(style="width:1%")
      tbody
        each product in products
          tr
            td= product.name
            td= product.vendor_name || product.vendor_cuit
            td= formatCurrency(product.vendor_price)
            td= formatCurrency(product.customer_price)
            td= product.category
            td
              a.btn.btn-sm.btn-warning(href=`/api/products/${product.vendor_cuit}/${encodeURIComponent(product.name)}/edit`) Editar

  if totalPages > 1
    .flex-between(style="margin-top:1rem")
      p(style="margin:0;font-size:0.8rem;color:#64748b") Página #{currentPage} de #{totalPages}
      .flex-gap
        - for (let page = 1; page <= totalPages; page++)
          a.btn.btn-sm(
            class=page === currentPage ? 'btn-primary' : 'btn-secondary',
            href=`/api/products?view=${encodeURIComponent(viewMode || 'all')}&search=${encodeURIComponent(searchTerm || '')}&page=${page}`
            hx-get=`/api/products?view=${encodeURIComponent(viewMode || 'all')}&search=${encodeURIComponent(searchTerm || '')}&page=${page}`
            hx-target="#product-table"
            hx-swap="innerHTML"
          )= page
else
  .tbl-wrap
    .empty
      i.bi.bi-box-seam-fill.empty-ico
      p.empty-title No hay productos para los filtros seleccionados.
      a.btn.btn-sm.btn-primary(href="/api/products/new" style="margin-top:0.75rem") Crear producto

  if totalPages > 1
    nav.mt-4(aria-label="Paginación de productos")
      ul.pagination.justify-content-center.mb-0
        li.page-item(class=currentPage === 1 ? 'disabled' : '')
          a.page-link(
            href=`/api/products?view=${encodeURIComponent(viewMode || 'all')}&search=${encodeURIComponent(searchTerm || '')}&page=${currentPage - 1}`
            hx-get=`/api/products?view=${encodeURIComponent(viewMode || 'all')}&search=${encodeURIComponent(searchTerm || '')}&page=${currentPage - 1}`
            hx-target="#product-table"
            hx-swap="innerHTML"
          ) Anterior
        - for (let page = 1; page <= totalPages; page++)
          li.page-item(class=page === currentPage ? 'active' : '')
            a.page-link(
              href=`/api/products?view=${encodeURIComponent(viewMode || 'all')}&search=${encodeURIComponent(searchTerm || '')}&page=${page}`
              hx-get=`/api/products?view=${encodeURIComponent(viewMode || 'all')}&search=${encodeURIComponent(searchTerm || '')}&page=${page}`
              hx-target="#product-table"
              hx-swap="innerHTML"
            )= page
        li.page-item(class=currentPage === totalPages ? 'disabled' : '')
          a.page-link(
            href=`/api/products?view=${encodeURIComponent(viewMode || 'all')}&search=${encodeURIComponent(searchTerm || '')}&page=${currentPage + 1}`
            hx-get=`/api/products?view=${encodeURIComponent(viewMode || 'all')}&search=${encodeURIComponent(searchTerm || '')}&page=${currentPage + 1}`
            hx-target="#product-table"
            hx-swap="innerHTML"
          ) Siguiente
else
  .alert.alert-info.d-flex.justify-content-between.align-items-center
    span No hay productos para los filtros seleccionados.
    a.btn.btn-sm.btn-primary(href="/api/products/new") Crear producto
