extends ../layout

block content
  - const productForm = formData || {}
  .container.mt-5
    .d-flex.justify-content-between.align-items-center.mb-3
      h2 Editar Producto
      a.btn.btn-outline-secondary(href="/api/products") Volver al listado

    if errorMessage
      .alert.alert-danger= errorMessage

    .row.justify-content-center
      .col-md-8
        .card.shadow
          .card-header.bg-dark.text-white
            h3.mb-0 Modificar Producto
          .card-body
            form(action=`/api/products/${product.vendor_cuit}/${encodedName}/edit`, method="POST")
              .row.mb-3
                .col-md-6
                  label.form-label Nombre
                  input.form-control(
                    type="text",
                    name="name",
                    required,
                    value=productForm.name || ""
                  )
                .col-md-6
                  label.form-label Proveedor
                  input.form-control(type="text", value=vendorName, disabled)
                  input(type="hidden", name="vendor_cuit", value=product.vendor_cuit)
                  .form-text CUIT: #{product.vendor_cuit}

              .row.mb-3
                .col-md-6
                  label.form-label Precio Proveedor
                  input.form-control(
                    type="number",
                    name="vendor_price",
                    min="0",
                    step="0.01",
                    required,
                    value=typeof productForm.vendor_price !== 'undefined' ? productForm.vendor_price : ""
                  )
                .col-md-6
                  label.form-label Precio Cliente
                  input.form-control(
                    type="number",
                    name="customer_price",
                    min="0",
                    step="0.01",
                    required,
                    value=typeof productForm.customer_price !== 'undefined' ? productForm.customer_price : ""
                  )

              .row.mb-3
                .col-md-6
                  label.form-label Categoría
                  select.form-select(name="category", required)
                    option(value="") Seleccionar categoría
                    each item in categories
                      option(
                        value=item,
                        selected=productForm.category === item
                      )= item

              .d-flex.justify-content-between.mt-4
                a.btn.btn-secondary(href="/api/products") Cancelar
                button.btn.btn-dark(type="submit") Guardar Cambios