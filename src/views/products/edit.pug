extends ../layout

block content
  - const productForm = formData || {}

  .pg-header
    h1.pg-title Editar Producto
    .pg-actions
      a.btn.btn-secondary(href="/api/products") Cancelar

  if errorMessage
    .flash.flash-err
      i.bi.bi-exclamation-triangle-fill(style="flex-shrink:0")
      span= errorMessage

  .crd(style="max-width:680px;margin:0 auto")
    .crd-head
      p.crd-title Modificar producto
    form#edit-form(action=`/api/products/${product.vendor_cuit}/${encodedName}/edit`, method="POST")
      .crd-body
        .grid-2
          .frm-group
            label.frm-label Nombre
            input.frm-ctrl(
              type="text",
              name="name",
              required,
              value=productForm.name || "",
              minlength="2",
              maxlength="100"
            )
          .frm-group
            label.frm-label Proveedor
            input.frm-ctrl(type="text", value=vendorName, disabled)
            input(type="hidden", name="vendor_cuit", value=product.vendor_cuit)
            span.frm-hint CUIT: #{product.vendor_cuit}

        .grid-2
          .frm-group
            label.frm-label Precio Proveedor
            input.frm-ctrl(
              type="number",
              name="vendor_price",
              min="0",
              step="0.01",
              required,
              placeholder="0.00",
              value=typeof productForm.vendor_price !== 'undefined' ? productForm.vendor_price : ""
            )
          .frm-group
            label.frm-label Precio Cliente
            input.frm-ctrl(
              type="number",
              name="customer_price",
              min="0",
              step="0.01",
              required,
              placeholder="0.00",
              value=typeof productForm.customer_price !== 'undefined' ? productForm.customer_price : ""
            )

        .frm-group(style="max-width:320px")
          label.frm-label Categoría
          select.frm-ctrl(name="category", required)
            option(value="") Seleccionar categoría
            each item in categories
              option(
                value=item,
                selected=productForm.category === item
              )= item

      .crd-foot
        span
        button.btn.btn-primary(type="submit", form="edit-form") Guardar Cambios