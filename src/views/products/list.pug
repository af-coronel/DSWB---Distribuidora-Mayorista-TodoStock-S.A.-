extends ../layout

block content

  .pg-header
    div
      h1.pg-title Catálogo de Productos
    .pg-actions
      a.btn.btn-primary(href="/api/products/new")
        i.bi.bi-plus-circle
        | Nuevo Producto

  .crd(style="margin-bottom:1.25rem")
    .crd-body
      .grid-2
        .frm-group(style="margin-bottom:0")
          label.frm-label Buscar por nombre
          input#search.frm-ctrl(
            type="text"
            name="search"
            value=searchTerm || ""
            placeholder="Ej. Detergente"
            autocomplete="off"
            hx-get="/api/products"
            hx-trigger="input changed delay:300ms"
            hx-target="#product-table"
            hx-swap="innerHTML"
            hx-include="[name='view']"
          )
        .frm-group(style="margin-bottom:0")
          label.frm-label Vista
          select#view.frm-ctrl(
            name="view"
            hx-get="/api/products"
            hx-trigger="change"
            hx-target="#product-table"
            hx-swap="innerHTML"
            hx-include="[name='search']"
          )
            option(value="all", selected=viewMode === 'all') Todos los productos
            option(value="public_sale", selected=viewMode === 'public_sale') Venta al público
            option(value="internal_use", selected=viewMode === 'internal_use') Consumo interno

  #product-table
    include _table
